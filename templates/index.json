        "remove_horizontal_spacing": false,
        "liquid": "<style>\n@import url('https://fonts.cdnfonts.com/css/neue-montreal');\n\n.reviews-carousel {\n  width: 100vw;\n  margin-left: calc(50% - 50vw);\nbackground: linear-gradient(180deg, #FFFFFF 0%, #FFFFFF 80%, #DCF0FD 100%);\n\n  padding: 100px 0;\n  position: relative;\n  overflow: hidden;\n  border-bottom: 1px solid #e8e8e8;\n}\n\n.reviews-eyebrow {\n  text-align: center;\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n  font-size: 10px;\n  font-weight: 500;\n  letter-spacing: 3px;\n  text-transform: uppercase;\n  color: #999;\n  margin-bottom: 50px;\n}\n\n.reviews-container {\n  max-width: 1100px;\n  margin: 0 auto;\n  position: relative;\n  padding: 0 80px;\n  overflow: hidden;\n}\n\n.reviews-wrapper {\n  display: flex;\n  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);\n}\n\n.review-slide {\n  min-width: 100%;\n  flex: 0 0 100%;\n  text-align: center;\n  box-sizing: border-box;\n}\n\n.stars {\n  font-size: 18px;\n  color: #000;\n  margin-bottom: 36px;\n  letter-spacing: 5px;\n}\n\n.review-text {\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n  font-size: 26px;\n  line-height: 1.55;\n  color: #000;\n  font-weight: 300;\n  margin: 0 auto 44px;\n  max-width: 900px;\n  letter-spacing: -0.5px;\n}\n\n.review-text em {\n  font-style: italic;\n  font-weight: 400;\n}\n\n.review-footer {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 16px;\n}\n\n.review-footer-line {\n  width: 30px;\n  height: 1px;\n  background: #ccc;\n}\n\n.review-author {\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n  font-size: 10px;\n  letter-spacing: 3px;\n  text-transform: uppercase;\n  color: #999;\n  font-weight: 500;\n}\n\n/* Flèches */\n.nav-arrow {\n  position: absolute;\n  top: 50%;\n  transform: translateY(-50%);\n  background: transparent;\n  border: 1px solid #e0e0e0;\n  width: 44px;\n  height: 44px;\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  cursor: pointer;\n  z-index: 10;\n  transition: all 0.25s ease;\n  color: #000;\n  font-size: 20px;\n  line-height: 1;\n  padding: 0;\n}\n\n.nav-arrow:hover {\n  background: #000;\n  border-color: #000;\n  color: #fff;\n}\n\n.nav-arrow.prev { left: 0; }\n.nav-arrow.next { right: 0; }\n\n/* Dots */\n.reviews-dots {\n  display: flex;\n  justify-content: center;\n  gap: 8px;\n  margin-top: 48px;\n}\n\n.reviews-dot {\n  width: 5px;\n  height: 5px;\n  border-radius: 50%;\n  background: #ddd;\n  cursor: pointer;\n  transition: all 0.3s ease;\n  border: none;\n  padding: 0;\n}\n\n.reviews-dot.active {\n  background: #000;\n  width: 20px;\n  border-radius: 3px;\n}\n\n/* MOBILE */\n@media (max-width: 768px) {\n  .reviews-carousel { padding: 70px 0; }\n  .reviews-container { padding: 0 55px; }\n  .review-text { font-size: 18px; }\n  .stars { font-size: 15px; margin-bottom: 26px; }\n  .nav-arrow { width: 36px; height: 36px; font-size: 16px; }\n}\n</style>\n\n<div class=\"reviews-carousel\">\n  <div class=\"reviews-eyebrow\">Ce qu'ils disent</div>\n\n  <div class=\"reviews-container\">\n    <button class=\"nav-arrow prev\" id=\"reviewPrev\">&#8592;</button>\n    <button class=\"nav-arrow next\" id=\"reviewNext\">&#8594;</button>\n\n    <div class=\"reviews-wrapper\" id=\"reviewsWrapper\">\n\n      <div class=\"review-slide\">\n        <div class=\"stars\">★★★★★</div>\n        <p class=\"review-text\">\n          \"Je prends OORIGINE depuis environ quatre mois maintenant. Depuis que j'ai commencé, je me sens incroyable... extrêmement <em>en bonne santé, énergisée</em> et je peux même voir un <em>changement dans ma peau, mes cheveux et mon corps</em> pour le mieux.*\"\n        </p>\n        <div class=\"review-footer\">\n          <div class=\"review-footer-line\"></div>\n          <span class=\"review-author\">Gina</span>\n          <div class=\"review-footer-line\"></div>\n        </div>\n      </div>\n\n      <div class=\"review-slide\">\n        <div class=\"stars\">★★★★★</div>\n        <p class=\"review-text\">\n          \"Ce produit est incroyable ! Facilement l'un de mes suppléments préférés. L'<em>énergie que je ressens est pure et durable.</em> Ça favorise vraiment la <em>clarté d'esprit et un grand bien-être !</em> Content d'avoir essayé !*\"\n        </p>\n        <div class=\"review-footer\">\n          <div class=\"review-footer-line\"></div>\n          <span class=\"review-author\">Martin</span>\n          <div class=\"review-footer-line\"></div>\n        </div>\n      </div>\n\n      <div class=\"review-slide\">\n        <div class=\"stars\">★★★★★</div>\n        <p class=\"review-text\">\n          \"Après seulement quelques semaines, j'ai remarqué une <em>digestion beaucoup plus fluide</em> et une énergie constante tout au long de la journée. Je ne reviendrai jamais en arrière.*\"\n        </p>\n        <div class=\"review-footer\">\n          <div class=\"review-footer-line\"></div>\n          <span class=\"review-author\">Sophie</span>\n          <div class=\"review-footer-line\"></div>\n        </div>\n      </div>\n\n    </div>\n  </div>\n\n  <div class=\"reviews-dots\" id=\"reviewsDots\"></div>\n</div>\n\n<script>\n(function() {\n  var current = 0;\n  var wrapper = document.getElementById('reviewsWrapper');\n  var slides = wrapper.querySelectorAll('.review-slide');\n  var total = slides.length;\n  var dotsContainer = document.getElementById('reviewsDots');\n\n  // Créer les dots\n  for (var i = 0; i < total; i++) {\n    var dot = document.createElement('button');\n    dot.className = 'reviews-dot' + (i === 0 ? ' active' : '');\n    dot.setAttribute('data-index', i);\n    dot.addEventListener('click', function() {\n      goTo(parseInt(this.getAttribute('data-index')));\n    });\n    dotsContainer.appendChild(dot);\n  }\n\n  function updateDots() {\n    dotsContainer.querySelectorAll('.reviews-dot').forEach(function(d, i) {\n      d.classList.toggle('active', i === current);\n    });\n  }\n\n  function goTo(index) {\n    current = (index + total) % total;\n    wrapper.style.transform = 'translateX(-' + (current * 100) + '%)';\n    updateDots();\n  }\n\n  document.getElementById('reviewPrev').addEventListener('click', function() { goTo(current - 1); });\n  document.getElementById('reviewNext').addEventListener('click', function() { goTo(current + 1); });\n\n  // Auto-play\n  setInterval(function() { goTo(current + 1); }, 5000);\n\n  // Swipe mobile\n  var touchStartX = 0;\n  wrapper.addEventListener('touchstart', function(e) { touchStartX = e.changedTouches[0].screenX; }, { passive: true });\n  wrapper.addEventListener('touchend', function(e) {\n    var diff = touchStartX - e.changedTouches[0].screenX;\n    if (Math.abs(diff) > 50) goTo(current + (diff > 0 ? 1 : -1));\n  }, { passive: true });\n})();\n</script>",
