        "liquid": "<style>\n@import url('https://fonts.cdnfonts.com/css/neue-montreal');\n\n.oorigine-science-section {\n  width: 100vw;\n  margin-left: calc(50% - 50vw);\n  background: #ffffff;\n  padding: 120px 0 140px;\n  position: relative;\n}\n\n.oorigine-science-section::before {\n  content: '';\n  position: absolute;\n  top: 0; left: 0; right: 0; bottom: 0;\n  background-image:\n    linear-gradient(rgba(0,0,0,0.018) 1px, transparent 1px),\n    linear-gradient(90deg, rgba(0,0,0,0.018) 1px, transparent 1px);\n  background-size: 48px 48px;\n  pointer-events: none;\n}\n\n.oorigine-science-container {\n  max-width: 1280px;\n  margin: 0 auto;\n  padding: 0 60px;\n  position: relative;\n  z-index: 1;\n}\n\n/* ---- HEADER ---- */\n.oorigine-science-header {\n  text-align: center;\n  max-width: 820px;\n  margin: 0 auto 90px;\n}\n\n.oorigine-science-eyebrow {\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n  font-size: 10px;\n  font-weight: 500;\n  letter-spacing: 3px;\n  text-transform: uppercase;\n  color: #999;\n  margin-bottom: 22px;\n}\n\n.oorigine-science-main-title {\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n  font-size: 58px;\n  font-weight: 300;\n  line-height: 1.08;\n  color: #000;\n  margin-bottom: 28px;\n  letter-spacing: -2.5px;\n}\n\n.oorigine-science-main-title em {\n  font-style: italic;\n  font-weight: 300;\n}\n\n.oorigine-science-subtitle {\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n  font-size: 17px;\n  line-height: 1.75;\n  color: #777;\n  font-weight: 300;\n  max-width: 640px;\n  margin: 0 auto;\n}\n\n/* ---- GRILLE DE DONNÉES ---- */\n.oorigine-data-grid {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: 1px;\n  margin-bottom: 100px;\n  background: #e8e8e8;\n  border: 1px solid #e8e8e8;\n  border-radius: 4px;\n  overflow: hidden;\n}\n\n.oorigine-data-card {\n  background: #fff;\n  padding: 52px 44px;\n  text-align: center;\n  transition: background 0.3s ease;\n  position: relative;\n}\n\n.oorigine-data-card:hover {\n  background: #FAFAFA;\n}\n\n.oorigine-data-card::after {\n  content: '';\n  position: absolute;\n  bottom: 0; left: 0; right: 0;\n  height: 2px;\n  background: #DEF46C;\n  transform: scaleX(0);\n  transform-origin: left;\n  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n}\n\n.oorigine-data-card:hover::after {\n  transform: scaleX(1);\n}\n\n.oorigine-data-number {\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n  font-size: 68px;\n  font-weight: 300;\n  line-height: 1;\n  color: #000;\n  margin-bottom: 12px;\n  letter-spacing: -3px;\n}\n\n.oorigine-data-label {\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n  font-size: 10px;\n  text-transform: uppercase;\n  letter-spacing: 2px;\n  color: #bbb;\n  font-weight: 500;\n  margin-bottom: 14px;\n}\n\n.oorigine-data-description {\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n  font-size: 14px;\n  line-height: 1.65;\n  color: #888;\n  font-weight: 300;\n  max-width: 240px;\n  margin: 0 auto;\n}\n\n/* ---- DIVIDER ---- */\n.oorigine-section-divider {\n  display: flex;\n  align-items: center;\n  gap: 20px;\n  margin-bottom: 80px;\n}\n\n.oorigine-section-divider-line {\n  flex: 1;\n  height: 1px;\n  background: #e8e8e8;\n}\n\n.oorigine-section-divider-label {\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n  font-size: 10px;\n  font-weight: 500;\n  letter-spacing: 3px;\n  text-transform: uppercase;\n  color: #ccc;\n  white-space: nowrap;\n}\n\n/* ---- DUAL COLONNES ---- */\n.oorigine-video-dual-grid {\n  display: grid;\n  grid-template-columns: 1fr 1px 1fr;\n  gap: 0 70px;\n  align-items: start;\n}\n\n.oorigine-col-separator {\n  background: #e8e8e8;\n  height: 100%;\n  min-height: 600px;\n}\n\n.oorigine-video-col {\n  display: flex;\n  flex-direction: column;\n  gap: 44px;\n}\n\n/* En-tête de colonne */\n.oorigine-video-col-header {\n  padding-left: 0;\n}\n\n.oorigine-col-tag {\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n  font-size: 10px;\n  font-weight: 500;\n  letter-spacing: 2.5px;\n  text-transform: uppercase;\n  color: #999;\n  margin-bottom: 16px;\n}\n\n.oorigine-video-col-title {\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n  font-size: 34px;\n  font-weight: 400;\n  line-height: 1.15;\n  color: #000;\n  margin-bottom: 18px;\n  letter-spacing: -1px;\n}\n\n.oorigine-video-col-intro {\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n  font-size: 15px;\n  line-height: 1.75;\n  color: #777;\n  font-weight: 300;\n  border-left: 2px solid #DEF46C;\n  padding-left: 18px;\n  margin: 0;\n}\n\n/* Liste numérotée */\n.oorigine-video-list {\n  display: flex;\n  flex-direction: column;\n  gap: 0;\n  border: 1px solid #ebebeb;\n  border-radius: 4px;\n  overflow: hidden;\n}\n\n.oorigine-video-item {\n  display: flex;\n  gap: 22px;\n  align-items: flex-start;\n  padding: 24px 28px;\n  border-bottom: 1px solid #ebebeb;\n  transition: background 0.2s ease;\n}\n\n.oorigine-video-item:last-child {\n  border-bottom: none;\n}\n\n.oorigine-video-item:hover {\n  background: #FAFAFA;\n}\n\n.oorigine-video-icon {\n  width: 32px;\n  height: 32px;\n  min-width: 32px;\n  border-radius: 50%;\n  background: #f4f4f4;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n  font-size: 11px;\n  font-weight: 600;\n  color: #999;\n  letter-spacing: 0;\n  margin-top: 2px;\n}\n\n.oorigine-video-text strong {\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n  font-size: 15px;\n  font-weight: 600;\n  color: #000;\n  display: block;\n  margin-bottom: 5px;\n  letter-spacing: -0.2px;\n}\n\n.oorigine-video-text p {\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n  font-size: 14px;\n  line-height: 1.65;\n  color: #888;\n  font-weight: 300;\n  margin: 0;\n}\n\n/* ---- VIDÉO ---- */\n.oorigine-video-media-wrapper {\n  width: 100%;\n  border-radius: 6px;\n  overflow: hidden;\n  border: 1px solid #ebebeb;\n  transition: transform 0.4s ease, box-shadow 0.4s ease;\n}\n\n.oorigine-video-media-wrapper:hover {\n  transform: translateY(-4px);\n  box-shadow: 0 16px 48px rgba(0,0,0,0.08);\n}\n\n.oorigine-video-media-wrapper video {\n  width: 100%;\n  height: auto;\n  display: block;\n  mix-blend-mode: multiply;\n}\n\n/* ---- RESPONSIVE ---- */\n@media (max-width: 1024px) {\n  .oorigine-science-container { padding: 0 40px; }\n  .oorigine-data-grid { grid-template-columns: 1fr; }\n  .oorigine-video-dual-grid {\n    grid-template-columns: 1fr;\n    gap: 70px 0;\n  }\n  .oorigine-col-separator { display: none; }\n  .oorigine-science-main-title { font-size: 44px; }\n}\n\n@media (max-width: 640px) {\n  .oorigine-science-section { padding: 80px 0; }\n  .oorigine-science-container { padding: 0 24px; }\n  .oorigine-science-main-title { font-size: 34px; letter-spacing: -1.5px; }\n  .oorigine-data-card { padding: 40px 28px; }\n  .oorigine-data-number { font-size: 52px; }\n  .oorigine-video-col-title { font-size: 26px; }\n  .oorigine-science-header { margin-bottom: 60px; }\n}\n</style>\n\n<div class=\"oorigine-science-section\">\n  <div class=\"oorigine-science-container\">\n\n    <!-- HEADER -->\n    <div class=\"oorigine-science-header\">\n      <div class=\"oorigine-science-eyebrow\">Recherche clinique &amp; Formulation</div>\n      <h2 class=\"oorigine-science-main-title\">La science derrière <em>OORIGINE™</em></h2>\n      <p class=\"oorigine-science-subtitle\">\n        Le colostrum est le premier nutriment bioactif de la nature, soutenu par plus de 5 000 études cliniques et utilisé par les athlètes olympiques, les médecins et les biohackers du monde entier.\n      </p>\n    </div>\n\n    <!-- GRILLE DE DONNÉES -->\n    <div class=\"oorigine-data-grid\">\n      <div class=\"oorigine-data-card\">\n        <div class=\"oorigine-data-number\">400+</div>\n        <div class=\"oorigine-data-label\">Composés bioactifs</div>\n        <div class=\"oorigine-data-description\">Immunoglobulines, facteurs de croissance, prébiotiques et peptides antimicrobiens</div>\n      </div>\n      <div class=\"oorigine-data-card\">\n        <div class=\"oorigine-data-number\">5 000+</div>\n        <div class=\"oorigine-data-label\">Études publiées</div>\n        <div class=\"oorigine-data-description\">Décennies de recherche clinique validant les bienfaits du colostrum sur l'immunité</div>\n      </div>\n      <div class=\"oorigine-data-card\">\n        <div class=\"oorigine-data-number\">3×</div>\n        <div class=\"oorigine-data-label\">Plus d'immunoglobulines</div>\n        <div class=\"oorigine-data-description\">Que le lait maternel humain, pour une protection immunitaire maximale</div>\n      </div>\n    </div>\n\n    <!-- DIVIDER -->\n    <div class=\"oorigine-section-divider\">\n      <div class=\"oorigine-section-divider-line\"></div>\n      <div class=\"oorigine-section-divider-label\">Mécanisme d'action</div>\n      <div class=\"oorigine-section-divider-line\"></div>\n    </div>\n\n    <!-- DUAL COLONNES -->\n    <div class=\"oorigine-video-dual-grid\">\n\n      <!-- COLONNE GAUCHE -->\n      <div class=\"oorigine-video-col\">\n        <div class=\"oorigine-video-col-header\">\n          <div class=\"oorigine-col-tag\">Le problème</div>\n          <h3 class=\"oorigine-video-col-title\">Pourquoi vous en avez besoin</h3>\n          <p class=\"oorigine-video-col-intro\">\n            Vos surfaces intérieures (intestins, poumons, sinus) sont protégées par des muqueuses — votre première ligne de défense.\n          </p>\n        </div>\n\n        <div class=\"oorigine-video-list\">\n          <div class=\"oorigine-video-item\">\n            <div class=\"oorigine-video-icon\">01</div>\n            <div class=\"oorigine-video-text\">\n              <strong>Barrières affaiblies</strong>\n              <p>Pollution, stress, aliments transformés et pesticides détériorent ces barrières protectrices au quotidien.</p>\n            </div>\n          </div>\n          <div class=\"oorigine-video-item\">\n            <div class=\"oorigine-video-icon\">02</div>\n            <div class=\"oorigine-video-text\">\n              <strong>Perméabilité intestinale</strong>\n              <p>Les toxines traversent plus facilement, créant inflammation, fatigue chronique et déséquilibre immunitaire.</p>\n            </div>\n          </div>\n          <div class=\"oorigine-video-item\">\n            <div class=\"oorigine-video-icon\">03</div>\n            <div class=\"oorigine-video-text\">\n              <strong>Microbiome déséquilibré</strong>\n              <p>Une flore intestinale altérée affecte digestion, humeur, qualité de la peau et niveau d'énergie.</p>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"oorigine-video-media-wrapper\">\n          <video autoplay muted loop playsinline webkit-playsinline preload=\"auto\" disablePictureInPicture x-webkit-airplay=\"deny\">\n            <source src=\"https://cdn.shopify.com/videos/c/o/v/e61d65d0e6a3445c96e8e9ee708579dd.mp4\" type=\"video/mp4\">\n          </video>\n        </div>\n      </div>\n\n      <!-- SÉPARATEUR VERTICAL -->\n      <div class=\"oorigine-col-separator\"></div>\n\n      <!-- COLONNE DROITE -->\n      <div class=\"oorigine-video-col\">\n        <div class=\"oorigine-video-col-header\">\n          <div class=\"oorigine-col-tag\">La solution</div>\n          <h3 class=\"oorigine-video-col-title\">Comment ça fonctionne</h3>\n          <p class=\"oorigine-video-col-intro\">\n            Le colostrum exploite 300 millions d'années d'évolution pour restaurer, renforcer et protéger votre corps de l'intérieur.\n          </p>\n        </div>\n\n        <div class=\"oorigine-video-list\">\n          <div class=\"oorigine-video-item\">\n            <div class=\"oorigine-video-icon\">01</div>\n            <div class=\"oorigine-video-text\">\n              <strong>Répare les barrières</strong>\n              <p>Les facteurs de croissance (IGF-1, TGF-β) régénèrent les tissus intestinaux en 7 à 14 jours seulement.</p>\n            </div>\n          </div>\n          <div class=\"oorigine-video-item\">\n            <div class=\"oorigine-video-icon\">02</div>\n            <div class=\"oorigine-video-text\">\n              <strong>Renforce l'immunité</strong>\n              <p>Les immunoglobulines IgG, IgA et lactoferrine neutralisent pathogènes et inflammations chroniques.</p>\n            </div>\n          </div>\n          <div class=\"oorigine-video-item\">\n            <div class=\"oorigine-video-icon\">03</div>\n            <div class=\"oorigine-video-text\">\n              <strong>Nourrit le microbiome</strong>\n              <p>Les prébiotiques et peptides antimicrobiens restaurent l'équilibre naturel des bonnes bactéries.</p>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"oorigine-video-media-wrapper\">\n          <video autoplay muted loop playsinline webkit-playsinline preload=\"auto\" disablePictureInPicture x-webkit-airplay=\"deny\">\n            <source src=\"https://cdn.shopify.com/videos/c/o/v/0fee48cdeaf1477c88f2989c5f6be2e4.mp4\" type=\"video/mp4\">\n          </video>\n        </div>\n      </div>\n\n    </div>\n  </div>\n</div>\n\n<script>\n(function() {\n  function forcePlayVideos() {\n    document.querySelectorAll('.oorigine-video-media-wrapper video').forEach(function(video) {\n      video.muted = true;\n      var p = video.play();\n      if (p !== undefined) {\n        p.catch(function() {\n          ['scroll','touchstart'].forEach(function(e) {\n            document.addEventListener(e, function h() {\n              video.play();\n              document.removeEventListener(e, h);\n            }, { passive: true });\n          });\n        });\n      }\n    });\n  }\n  document.readyState === 'loading'\n    ? document.addEventListener('DOMContentLoaded', forcePlayVideos)\n    : forcePlayVideos();\n  setTimeout(forcePlayVideos, 600);\n})();\n</script>",
