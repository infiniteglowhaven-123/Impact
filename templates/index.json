            "liquid": "<style>\n@import url('https://fonts.cdnfonts.com/css/neue-montreal');\n\n.pdp-accordion-block {\n  max-width: 700px;\n  margin: 0 auto;\n  padding: 0 20px;\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n}\n\n/* LIGNE DES ONGLETS */\n.pdp-accordion-nav {\n  display: flex;\n  border-bottom: 1px solid #e0e0e0;\n  overflow-x: auto;\n  scrollbar-width: none;\n  -webkit-overflow-scrolling: touch;\n  position: relative;\n}\n\n.pdp-accordion-nav::-webkit-scrollbar { display: none; }\n\n.pdp-acc-btn {\n  flex: 0 0 auto;\n  background: transparent;\n  border: none;\n  border-bottom: 2px solid transparent;\n  margin-bottom: -1px;\n  padding: 12px 18px;\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n  font-size: 11px;\n  font-weight: 500;\n  letter-spacing: 1.5px;\n  text-transform: uppercase;\n  color: #aaa;\n  cursor: pointer;\n  white-space: nowrap;\n  transition: all 0.25s ease;\n  display: flex;\n  align-items: center;\n  gap: 6px;\n}\n\n.pdp-acc-btn:hover { color: #000; }\n\n.pdp-acc-btn.active {\n  color: #000;\n  border-bottom-color: #DEF46C;\n}\n\n.pdp-acc-btn .pdp-acc-arrow {\n  font-size: 8px;\n  transition: transform 0.25s ease;\n  display: inline-block;\n  color: #ccc;\n}\n\n.pdp-acc-btn.active .pdp-acc-arrow {\n  transform: rotate(180deg);\n  color: #000;\n}\n\n/* PANNEAU */\n.pdp-acc-panel {\n  max-height: 0;\n  overflow: hidden;\n  transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;\n  opacity: 0;\n  border-bottom: 1px solid transparent;\n}\n\n.pdp-acc-panel.active {\n  max-height: 600px;\n  opacity: 1;\n  border-bottom-color: #e0e0e0;\n}\n\n.pdp-acc-panel-inner {\n  padding: 24px 0 28px;\n}\n\n/* BULLET POINTS */\n.pdp-list {\n  list-style: none;\n  padding: 0;\n  margin: 0;\n  display: flex;\n  flex-direction: column;\n  gap: 10px;\n}\n\n.pdp-list li {\n  display: flex;\n  align-items: flex-start;\n  gap: 12px;\n  font-size: 14px;\n  line-height: 1.65;\n  color: #444;\n  font-weight: 300;\n}\n\n.pdp-list li::before {\n  content: '—';\n  color: #DEF46C;\n  font-weight: 700;\n  flex-shrink: 0;\n  margin-top: 1px;\n}\n\n/* TEXTE */\n.pdp-text {\n  font-size: 14px;\n  line-height: 1.75;\n  color: #555;\n  font-weight: 300;\n  margin: 0 0 14px;\n}\n\n.pdp-text:last-child { margin-bottom: 0; }\n\n/* PDF */\n.pdp-pdf-link {\n  display: inline-flex;\n  align-items: center;\n  gap: 8px;\n  margin-top: 16px;\n  font-size: 11px;\n  font-weight: 600;\n  letter-spacing: 1.5px;\n  text-transform: uppercase;\n  color: #000;\n  text-decoration: none;\n  border-bottom: 1px solid #000;\n  padding-bottom: 2px;\n  transition: opacity 0.2s ease;\n}\n\n.pdp-pdf-link:hover { opacity: 0.5; }\n\n/* BADGE INGRÉDIENT */\n.pdp-ingredient-badge {\n  display: inline-flex;\n  align-items: center;\n  gap: 10px;\n  background: #f4f4f4;\n  border: 1px solid #e8e8e8;\n  border-radius: 4px;\n  padding: 14px 20px;\n  font-size: 13px;\n  font-weight: 500;\n  color: #000;\n}\n\n.pdp-ingredient-badge::before {\n  content: '✦';\n  color: #DEF46C;\n  font-size: 12px;\n}\n\n/* POSOLOGIE */\n.pdp-dosage-box {\n  background: #f9f9f9;\n  border: 1px solid #ebebeb;\n  border-radius: 4px;\n  padding: 20px 24px;\n  font-size: 14px;\n  line-height: 1.75;\n  color: #444;\n  font-weight: 300;\n}\n\n.pdp-dosage-box strong {\n  display: block;\n  font-size: 11px;\n  font-weight: 600;\n  letter-spacing: 2px;\n  text-transform: uppercase;\n  color: #000;\n  margin-bottom: 10px;\n}\n\n@media (max-width: 640px) {\n  .pdp-acc-btn {\n    font-size: 10px;\n    padding: 11px 12px;\n    letter-spacing: 1px;\n  }\n}\n</style>\n\n<div class=\"pdp-accordion-block\">\n\n  <!-- NAV -->\n  <div class=\"pdp-accordion-nav\">\n    <button class=\"pdp-acc-btn\" data-acc=\"benefices\">Bénéfices <span class=\"pdp-acc-arrow\">▼</span></button>\n    <button class=\"pdp-acc-btn\" data-acc=\"tests\">Tests tiers <span class=\"pdp-acc-arrow\">▼</span></button>\n    <button class=\"pdp-acc-btn\" data-acc=\"description\">Description <span class=\"pdp-acc-arrow\">▼</span></button>\n    <button class=\"pdp-acc-btn\" data-acc=\"utilisation\">Utilisation <span class=\"pdp-acc-arrow\">▼</span></button>\n    <button class=\"pdp-acc-btn\" data-acc=\"ingredients\">Ingrédients <span class=\"pdp-acc-arrow\">▼</span></button>\n  </div>\n\n  <!-- PANNEAUX -->\n  <div class=\"pdp-acc-panel\" id=\"pdpacc-benefices\">\n    <div class=\"pdp-acc-panel-inner\">\n      <ul class=\"pdp-list\">\n        <li>Soutient la santé intestinale et renforce la paroi intestinale</li>\n        <li>Renforce les défenses immunitaires naturelles</li>\n        <li>Améliore la qualité de la peau, des cheveux et des ongles</li>\n        <li>Soutient la récupération et les performances physiques</li>\n        <li>Favorise l'équilibre du microbiome et réduit les ballonnements</li>\n        <li>Apporte énergie et vitalité au quotidien</li>\n      </ul>\n    </div>\n  </div>\n\n  <div class=\"pdp-acc-panel\" id=\"pdpacc-tests\">\n    <div class=\"pdp-acc-panel-inner\">\n      <ul class=\"pdp-list\">\n        <li>Testé pour la pureté et la sécurité par des laboratoires certifiés indépendants</li>\n        <li>Absence vérifiée de bactéries nocives, métaux lourds et contaminants</li>\n        <li>Conforme à toutes les normes de qualité en vigueur</li>\n        <li>Étiquetage clair et contrôles de stabilité effectués à chaque lot</li>\n      </ul>\n      <a class=\"pdp-pdf-link\" href=\"https://cdn.shopify.com/s/files/1/0713/6952/3289/files/Colostrum_COA_Redacted-2.pdf.pdf?v=1772227906\" target=\"_blank\">↓ Voir le certificat d'analyse (PDF)</a>\n    </div>\n  </div>\n\n  <div class=\"pdp-acc-panel\" id=\"pdpacc-description\">\n    <div class=\"pdp-acc-panel-inner\">\n      <p class=\"pdp-text\">Le colostrum, surnommé le premier aliment de la nature, est produit par les vaches juste après la naissance de leur veau. Ce superaliment riche en nutriments regorge de vitamines essentielles, d'anticorps et de composés immunostimulants qui soutiennent la santé globale.</p>\n      <p class=\"pdp-text\">Notre colostrum est issu de vaches laitières élevées en pâturage, nourries à l'herbe, et n'est récolté qu'après que les veaux ont été pleinement nourris. Chaque lot est 100% pur et traçable jusqu'aux fermes partenaires de confiance.</p>\n    </div>\n  </div>\n\n  <div class=\"pdp-acc-panel\" id=\"pdpacc-utilisation\">\n    <div class=\"pdp-acc-panel-inner\">\n      <div class=\"pdp-dosage-box\">\n        <strong>Posologie recommandée</strong>\n         Prenez une à trois portion par jour, une le matin à jeun, pour une absorption optimale des immunoglobulines et facteurs de croissance. Continuez la prise au minimum 8 semaines pour des résultats mesurables. Chaque contenant offre 120 portions — consultez un professionnel de santé si vous avez des questions spécifiques à votre situation.\n      </div>\n    </div>\n  </div>\n\n  <div class=\"pdp-acc-panel\" id=\"pdpacc-ingredients\">\n    <div class=\"pdp-acc-panel-inner\">\n      <p class=\"pdp-text\">Formule 100% pure, sans additifs ni charges inutiles.</p>\n      <div class=\"pdp-ingredient-badge\">Colostrum bovin entier</div>\n    </div>\n  </div>\n\n</div>\n\n<script>\n(function() {\n  var btns = document.querySelectorAll('.pdp-acc-btn');\n\n  btns.forEach(function(btn) {\n    btn.addEventListener('click', function() {\n      var target = btn.getAttribute('data-acc');\n      var panel = document.getElementById('pdpacc-' + target);\n      var isActive = btn.classList.contains('active');\n\n      // Ferme tout\n      btns.forEach(function(b) { b.classList.remove('active'); });\n      document.querySelectorAll('.pdp-acc-panel').forEach(function(p) { p.classList.remove('active'); });\n\n      // Si pas déjà ouvert, ouvre\n      if (!isActive) {\n        btn.classList.add('active');\n        panel.classList.add('active');\n      }\n    });\n  });\n})();\n</script>"
