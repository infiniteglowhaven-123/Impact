        "remove_horizontal_spacing": false,
        "liquid": "<style>\n@import url('https://fonts.cdnfonts.com/css/neue-montreal');\n\n.imagine-section {\n  width: 100vw;\n  margin-left: calc(50% - 50vw);\n  background: #fff;\n  padding: 100px 20px;\n}\n\n.imagine-container {\n  max-width: 1100px;\n  margin: 0 auto;\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 80px;\n  align-items: center;\n}\n\n/* ---- GAUCHE : SLIDER ---- */\n.imagine-slider-wrap {\n  position: relative;\n  overflow: hidden;\n}\n\n.imagine-slider-track {\n  display: flex;\n  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);\n}\n\n.imagine-slide {\n  min-width: 100%;\n  flex: 0 0 100%;\n  position: relative;\n  border-radius: 6px;\n  overflow: hidden;\n  border: 1px solid #e8e8e8;\n}\n\n.imagine-slide img {\n  width: 100%;\n  height: auto;\n  display: block;\n  object-fit: cover;\n}\n\n/* Labels AVANT / APRÈS */\n.imagine-slide-labels {\n  position: absolute;\n  bottom: 16px;\n  left: 0;\n  right: 0;\n  display: flex;\n  justify-content: space-between;\n  padding: 0 16px;\n  pointer-events: none;\n}\n\n.imagine-label {\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n  font-size: 9px;\n  font-weight: 600;\n  letter-spacing: 2px;\n  text-transform: uppercase;\n  color: #fff;\n  background: rgba(0,0,0,0.45);\n  padding: 5px 10px;\n  border-radius: 3px;\n  backdrop-filter: blur(4px);\n}\n\n/* Dots */\n.imagine-dots {\n  display: flex;\n  justify-content: center;\n  gap: 8px;\n  margin-top: 18px;\n}\n\n.imagine-dot {\n  width: 5px;\n  height: 5px;\n  border-radius: 50%;\n  background: #ddd;\n  border: none;\n  cursor: pointer;\n  padding: 0;\n  transition: all 0.3s ease;\n}\n\n.imagine-dot.active {\n  background: #000;\n  width: 20px;\n  border-radius: 3px;\n}\n\n/* Flèches */\n.imagine-arrows {\n  display: flex;\n  justify-content: center;\n  gap: 12px;\n  margin-top: 16px;\n}\n\n.imagine-arrow {\n  width: 38px;\n  height: 38px;\n  border-radius: 50%;\n  border: 1px solid #e0e0e0;\n  background: transparent;\n  cursor: pointer;\n  font-size: 16px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  transition: all 0.25s ease;\n  color: #000;\n}\n\n.imagine-arrow:hover {\n  background: #000;\n  color: #fff;\n  border-color: #000;\n}\n\n/* ---- DROITE : TEXTE ---- */\n.imagine-content {\n  display: flex;\n  flex-direction: column;\n  gap: 28px;\n}\n\n.imagine-eyebrow {\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n  font-size: 10px;\n  font-weight: 500;\n  letter-spacing: 3px;\n  text-transform: uppercase;\n  color: #999;\n}\n\n.imagine-title {\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n  font-size: 42px;\n  font-weight: 300;\n  line-height: 1.1;\n  letter-spacing: -2px;\n  color: #000;\n  margin: 0;\n}\n\n.imagine-title em {\n  font-style: italic;\n}\n\n.imagine-title .imagine-highlight {\n  background: #DEF46C;\n  padding: 0 6px;\n  border-radius: 3px;\n  font-style: normal;\n}\n\n.imagine-list {\n  list-style: none;\n  padding: 0;\n  margin: 0;\n  display: flex;\n  flex-direction: column;\n  gap: 12px;\n}\n\n.imagine-list li {\n  display: flex;\n  align-items: flex-start;\n  gap: 12px;\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n  font-size: 14px;\n  line-height: 1.65;\n  color: #555;\n  font-weight: 300;\n}\n\n.imagine-list li::before {\n  content: '—';\n  color: #DEF46C;\n  font-weight: 700;\n  flex-shrink: 0;\n  margin-top: 1px;\n}\n\n.imagine-disclaimer {\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n  font-size: 11px;\n  color: #bbb;\n  font-weight: 300;\n  line-height: 1.6;\n}\n\n/* CTA */\n.imagine-cta {\n  display: inline-flex;\n  align-items: center;\n  gap: 10px;\n  background: #DEF46C;\n  color: #000;\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n  font-size: 11px;\n  font-weight: 600;\n  letter-spacing: 2px;\n  text-transform: uppercase;\n  padding: 16px 28px;\n  border-radius: 3px;\n  text-decoration: none;\n  border: 1px solid #000;\n  transition: all 0.25s ease;\n  align-self: flex-start;\n}\n\n.imagine-cta:hover {\n  background: #000;\n  color: #DEF46C;\n}\n\n/* RESPONSIVE */\n@media (max-width: 968px) {\n  .imagine-container {\n    grid-template-columns: 1fr;\n    gap: 50px;\n  }\n  .imagine-title {\n    font-size: 32px;\n    letter-spacing: -1px;\n  }\n}\n\n@media (max-width: 640px) {\n  .imagine-section { padding: 70px 16px; }\n  .imagine-title { font-size: 26px; }\n}\n</style>\n\n<div class=\"imagine-section\">\n  <div class=\"imagine-container\">\n\n    <!-- GAUCHE : SLIDER -->\n    <div class=\"imagine-slider-wrap\">\n      <div class=\"imagine-slider-track\" id=\"imagineTrack\">\n\n        <!-- SLIDE 1 -->\n        <div class=\"imagine-slide\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0713/6952/3289/files/bloat-control-805863_95b30eeb-4442-45bd-bb7e-738f921fe0ac.webp?v=1772231354\" alt=\"Avant après 1\">\n          <div class=\"imagine-slide-labels\">\n            <span class=\"imagine-label\">Avant</span>\n            <span class=\"imagine-label\">Après</span>\n          </div>\n        </div>\n\n        <!-- SLIDE 2 -->\n        <div class=\"imagine-slide\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0713/6952/3289/files/bloat-control-513909.webp?v=1772231359\" alt=\"Avant après 2\">\n          <div class=\"imagine-slide-labels\">\n            <span class=\"imagine-label\">Avant</span>\n            <span class=\"imagine-label\">Après</span>\n          </div>\n        </div>\n\n        <!-- SLIDE 3 -->\n        <div class=\"imagine-slide\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0713/6952/3289/files/bloat-control-492521.webp?v=1772231356\" alt=\"Avant après 3\">\n          <div class=\"imagine-slide-labels\">\n            <span class=\"imagine-label\">Avant</span>\n            <span class=\"imagine-label\">Après</span>\n          </div>\n        </div>\n\n      </div>\n\n      <!-- DOTS -->\n      <div class=\"imagine-dots\" id=\"imagineDots\"></div>\n\n      <!-- FLÈCHES -->\n      <div class=\"imagine-arrows\">\n        <button class=\"imagine-arrow\" id=\"imaginePrev\">&#8592;</button>\n        <button class=\"imagine-arrow\" id=\"imagineNext\">&#8594;</button>\n      </div>\n    </div>\n\n    <!-- DROITE : TEXTE -->\n    <div class=\"imagine-content\">\n      <div class=\"imagine-eyebrow\">Transformations réelles</div>\n      <h2 class=\"imagine-title\">\n        Imaginez-vous<br>\n        <span class=\"imagine-highlight\">sans</span> douleur<br>\n        <em>intestinale.</em>\n      </h2>\n\n      \n\n      <p class=\"imagine-disclaimer\">\n        †Résultats basés sur une étude auprès de clients OORIGINE après 8 semaines d'utilisation. Les résultats peuvent varier.\n      </p>\n\n      <a href=\"#featured-product\" class=\"imagine-cta\">\n        Commencer ma transformation →\n      </a>\n    </div>\n\n  </div>\n</div>\n\n<script>\n(function() {\n  var track = document.getElementById('imagineTrack');\n  var dotsContainer = document.getElementById('imagineDots');\n  var slides = track.querySelectorAll('.imagine-slide');\n  var total = slides.length;\n  var current = 0;\n\n  // Dots\n  for (var i = 0; i < total; i++) {\n    var dot = document.createElement('button');\n    dot.className = 'imagine-dot' + (i === 0 ? ' active' : '');\n    dot.setAttribute('data-i', i);\n    dot.addEventListener('click', function() {\n      goTo(parseInt(this.getAttribute('data-i')));\n    });\n    dotsContainer.appendChild(dot);\n  }\n\n  function updateDots() {\n    dotsContainer.querySelectorAll('.imagine-dot').forEach(function(d, i) {\n      d.classList.toggle('active', i === current);\n    });\n  }\n\n  function goTo(index) {\n    current = (index + total) % total;\n    track.style.transform = 'translateX(-' + (current * 100) + '%)';\n    updateDots();\n  }\n\n  document.getElementById('imaginePrev').addEventListener('click', function() { goTo(current - 1); });\n  document.getElementById('imagineNext').addEventListener('click', function() { goTo(current + 1); });\n\n  // Autoplay\n  setInterval(function() { goTo(current + 1); }, 4000);\n\n  // Swipe mobile\n  var startX = 0;\n  track.addEventListener('touchstart', function(e) { startX = e.changedTouches[0].screenX; }, { passive: true });\n  track.addEventListener('touchend', function(e) {\n    var diff = startX - e.changedTouches[0].screenX;\n    if (Math.abs(diff) > 50) goTo(current + (diff > 0 ? 1 : -1));\n  }, { passive: true });\n})();\n</script>",
