        "liquid": "<style>\n@import url('https://fonts.cdnfonts.com/css/neue-montreal');\n\n.transformational-section {\n  width: 100vw;\n  margin-left: calc(50% - 50vw);\n  background: linear-gradient(180deg, #DCF0FD 0%, #FFFFFF 80%, #DCF0FD 100%);\n  padding: 100px 20px 80px;\n}\n\n.transformational-section .section-header {\n  text-align: center;\n  margin-bottom: 60px;\n}\n\n.transformational-section .section-tag {\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n  font-size: 10px;\n  letter-spacing: 3px;\n  text-transform: uppercase;\n  color: #999;\n  margin-bottom: 14px;\n}\n\n.transformational-section .section-title {\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n  font-size: 46px;\n  font-weight: 300;\n  color: #000;\n  letter-spacing: -2px;\n  line-height: 1.1;\n}\n\n.transformational-section .section-title em {\n  font-style: italic;\n}\n\n/* BOX PRINCIPALE */\n.transformational-section .results-container {\n  max-width: 1100px;\n  margin: 0 auto;\n}\n\n.transformational-section .results-box {\n  background: #fff;\n  border: 1px solid #e0e0e0;\n  border-radius: 6px;\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  margin-bottom: 50px;\n  overflow: hidden;\n  box-shadow: 0 4px 30px rgba(0,0,0,0.05);\n}\n\n/* IMAGE */\n.transformational-section .results-image {\n  position: relative;\n  min-height: 420px;\n}\n\n.transformational-section .results-image img {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  display: none;\n}\n\n.transformational-section .results-image img.active {\n  display: block;\n}\n\n/* CONTENU */\n.transformational-section .results-content {\n  padding: 44px 44px 40px;\n  display: flex;\n  flex-direction: column;\n  border-left: 1px solid #e8e8e8;\n}\n\n/* TABS */\n.transformational-section .tabs-row {\n  display: flex;\n  gap: 0;\n  margin-bottom: 36px;\n  border: 1px solid #e0e0e0;\n  border-radius: 4px;\n  overflow: hidden;\n}\n\n.transformational-section .tab-btn {\n  flex: 1;\n  padding: 11px 10px;\n  background: transparent;\n  border: none;\n  border-right: 1px solid #e0e0e0;\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n  font-size: 10px;\n  letter-spacing: 1.5px;\n  text-transform: uppercase;\n  font-weight: 500;\n  cursor: pointer;\n  transition: all 0.25s ease;\n  color: #999;\n}\n\n.transformational-section .tab-btn:last-child {\n  border-right: none;\n}\n\n.transformational-section .tab-btn.active {\n  background: #DEF46C;\n  color: #000;\n}\n\n/* CONTENU TAB */\n.transformational-section .tab-content {\n  display: none;\n  flex: 1;\n}\n\n.transformational-section .tab-content.active {\n  display: block;\n}\n\n.transformational-section .content-title {\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n  font-size: 20px;\n  font-weight: 500;\n  margin-bottom: 16px;\n  color: #000;\n  letter-spacing: -0.3px;\n}\n\n.transformational-section .content-text {\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n  font-size: 14px;\n  line-height: 1.75;\n  color: #666;\n  font-weight: 300;\n}\n\n/* STATS */\n.transformational-section .stats-grid {\n  display: flex;\n  justify-content: center;\n  gap: 0;\n  flex-wrap: wrap;\n  border: 1px solid #e0e0e0;\n  border-radius: 6px;\n  overflow: hidden;\n  background: #fff;\n}\n\n.transformational-section .stat-box {\n  flex: 1;\n  min-width: 160px;\n  text-align: center;\n  padding: 36px 24px;\n  border-right: 1px solid #e0e0e0;\n  transition: background 0.2s ease;\n  position: relative;\n}\n\n.transformational-section .stat-box::after {\n  content: '';\n  position: absolute;\n  bottom: 0; left: 0; right: 0;\n  height: 2px;\n  background: #DEF46C;\n  transform: scaleX(0);\n  transform-origin: left;\n  transition: transform 0.4s ease;\n}\n\n.transformational-section .stat-box:hover::after {\n  transform: scaleX(1);\n}\n\n.transformational-section .stat-box:hover {\n  background: #FAFAFA;\n}\n\n.transformational-section .stat-box:last-child {\n  border-right: none;\n}\n\n.transformational-section .stat-number {\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n  font-size: 52px;\n  font-weight: 300;\n  color: #000;\n  line-height: 1;\n  margin-bottom: 12px;\n  letter-spacing: -2px;\n}\n\n.transformational-section .stat-label {\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n  font-size: 12px;\n  line-height: 1.5;\n  color: #888;\n  font-weight: 400;\n  max-width: 160px;\n  margin: 0 auto;\n}\n\n/* MOBILE */\n@media (max-width: 968px) {\n  .transformational-section .results-box {\n    grid-template-columns: 1fr;\n  }\n  .transformational-section .results-content {\n    border-left: none;\n    border-top: 1px solid #e8e8e8;\n    padding: 32px 28px;\n  }\n  .transformational-section .results-image {\n    min-height: 300px;\n  }\n  .transformational-section .section-title {\n    font-size: 34px;\n  }\n  .transformational-section .stats-grid {\n    flex-wrap: wrap;\n  }\n  .transformational-section .stat-box {\n    flex: 1 1 calc(50% - 1px);\n    min-width: 0;\n    border-bottom: 1px solid #e0e0e0;\n  }\n  .transformational-section .stat-box:nth-child(even) {\n    border-right: none;\n  }\n  .transformational-section .stat-box:nth-last-child(-n+2) {\n    border-bottom: none;\n  }\n}\n\n@media (max-width: 640px) {\n  .transformational-section {\n    padding: 70px 16px 60px;\n  }\n  .transformational-section .section-title {\n    font-size: 28px;\n    letter-spacing: -1px;\n  }\n  .transformational-section .tabs-row {\n    flex-direction: column;\n  }\n  .transformational-section .tab-btn {\n    border-right: none;\n    border-bottom: 1px solid #e0e0e0;\n    padding: 13px 16px;\n    text-align: left;\n  }\n  .transformational-section .tab-btn:last-child {\n    border-bottom: none;\n  }\n  .transformational-section .stat-number {\n    font-size: 40px;\n  }\n  .transformational-section .stat-box {\n    flex: 1 1 100%;\n    border-right: none;\n    border-bottom: 1px solid #e0e0e0;\n  }\n  .transformational-section .stat-box:last-child {\n    border-bottom: none;\n  }\n}\n</style>\n\n<div class=\"transformational-section\" id=\"transformational-section\">\n  <div class=\"section-header\">\n    <div class=\"section-tag\">[ Science &amp; Résultats ]</div>\n    <h2 class=\"section-title\">Puissance <em>naturelle</em></h2>\n  </div>\n\n  <div class=\"results-container\">\n    <div class=\"results-box\">\n      <div class=\"results-image\">\n        <img id=\"img-gut\" class=\"active\" src=\"https://cdn.shopify.com/s/files/1/0713/6952/3289/files/O_ORIGINE-20.svg?v=1770676555\" alt=\"Santé Intestinale\">\n        <img id=\"img-performance\" src=\"https://cdn.shopify.com/s/files/1/0713/6952/3289/files/imgi_43_image_80_1.jpg?v=1770676610\" alt=\"Performance\">\n        <img id=\"img-skin\" src=\"https://cdn.shopify.com/s/files/1/0713/6952/3289/files/Capture_d_ecran_le_2026-02-09_a_17.52.41.png?v=1770677567\" alt=\"Peau & Cheveux\">\n      </div>\n\n      <div class=\"results-content\">\n        <div class=\"tabs-row\">\n          <button class=\"tab-btn active\" data-tab=\"gut\">Santé intestinale</button>\n          <button class=\"tab-btn\" data-tab=\"performance\">Performance</button>\n          <button class=\"tab-btn\" data-tab=\"skin\">Peau &amp; Cheveux</button>\n        </div>\n\n        <div id=\"gut\" class=\"tab-content active\">\n          <h3 class=\"content-title\">▼ Santé Intestinale</h3>\n          <p class=\"content-text\">OORIGINE Colostrum™ favorise la santé digestive en fortifiant naturellement les quatre couches de votre barrière muqueuse intestinale, y compris la paroi intestinale, les cellules immunitaires et anticorps, la couche de mucus et l'écosystème intestinal.</p>\n        </div>\n\n        <div id=\"performance\" class=\"tab-content\">\n          <h3 class=\"content-title\">+ Performance</h3>\n          <p class=\"content-text\">OORIGINE Colostrum™ est une source naturelle de plus de 400 nutriments bioactifs, soutenant la performance et la récupération fitness. Les facteurs de croissance, comme IGF-1, soutiennent l'équilibre sain du glucose et alimentent le métabolisme cellulaire.</p>\n        </div>\n\n        <div id=\"skin\" class=\"tab-content\">\n          <h3 class=\"content-title\">✦ Peau &amp; Cheveux</h3>\n          <p class=\"content-text\">OORIGINE Colostrum™ offre une matrice de plus de 400 nutriments bioactifs, incluant exosomes, antioxydants, prébiotiques alimentaires entiers, facteurs de croissance, vitamines et peptides régénératifs.</p>\n        </div>\n      </div>\n    </div>\n\n    <!-- STATS -->\n    <div class=\"stats-grid\" id=\"statsGrid\">\n      <div class=\"stat-box\">\n        <div class=\"stat-number\" data-target=\"86\">0%</div>\n        <div class=\"stat-label\">Ont ressenti moins de ballonnements†</div>\n      </div>\n      <div class=\"stat-box\">\n        <div class=\"stat-number\" data-target=\"79\">0%</div>\n        <div class=\"stat-label\">Ont signalé moins de gaz et un meilleur bien-être digestif global†</div>\n      </div>\n      <div class=\"stat-box\">\n        <div class=\"stat-number\" data-target=\"75\">0%</div>\n        <div class=\"stat-label\">Ont signalé une amélioration significative de la régularité†</div>\n      </div>\n      <div class=\"stat-box\">\n        <div class=\"stat-number\" data-target=\"71\">0%</div>\n        <div class=\"stat-label\">Ont signalé moins d'inconfort intestinal après les repas†</div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\n(function() {\n  var hasAnimated = false;\n\n  var statsData = {\n    gut: [\n      { number: 86, label: 'Ont ressenti moins de ballonnements†' },\n      { number: 79, label: 'Ont signalé moins de gaz et un meilleur bien-être digestif global†' },\n      { number: 75, label: 'Ont signalé une amélioration significative de la régularité†' },\n      { number: 71, label: \"Ont signalé moins d'inconfort intestinal après les repas†\" }\n    ],\n    performance: [\n      { number: 83, label: 'Ont signalé une amélioration de la récupération fitness*' },\n      { number: 83, label: \"Ont signalé se sentir moins endoloris après l'entraînement*\" },\n      { number: 77, label: \"Ont signalé se sentir moins épuisés après l'effort*\" }\n    ],\n    skin: [\n      { number: 79, label: 'Ont signalé des cheveux plus épais†' },\n      { number: 80, label: 'Ont signalé une diminution des rides et une amélioration de leurs préoccupations cutanées†' }\n    ]\n  };\n\n  function animateNumber(el, target) {\n    var current = 0;\n    var delay = 1800 / target;\n    var timer = setInterval(function() {\n      current++;\n      el.textContent = current + '%';\n      if (current >= target) { el.textContent = target + '%'; clearInterval(timer); }\n    }, delay);\n  }\n\n  function animateAllStats() {\n    document.querySelectorAll('#transformational-section .stat-number').forEach(function(el) {\n      var target = parseInt(el.getAttribute('data-target'));\n      if (target > 0) { el.textContent = '0%'; animateNumber(el, target); }\n    });\n  }\n\n  function switchTab(tabName) {\n    document.querySelectorAll('.transformational-section .tab-btn').forEach(function(b) { b.classList.remove('active'); });\n    document.querySelectorAll('.transformational-section .tab-content').forEach(function(c) { c.classList.remove('active'); });\n    document.querySelectorAll('.transformational-section .results-image img').forEach(function(i) { i.classList.remove('active'); });\n\n    document.querySelector('[data-tab=\"' + tabName + '\"]').classList.add('active');\n    document.getElementById(tabName).classList.add('active');\n    document.getElementById('img-' + tabName).classList.add('active');\n\n    var grid = document.getElementById('statsGrid');\n    grid.innerHTML = statsData[tabName].map(function(s) {\n      return '<div class=\"stat-box\"><div class=\"stat-number\" data-target=\"' + s.number + '\">0%</div><div class=\"stat-label\">' + s.label + '</div></div>';\n    }).join('');\n    setTimeout(animateAllStats, 80);\n  }\n\n  document.querySelectorAll('.transformational-section .tab-btn').forEach(function(btn) {\n    btn.addEventListener('click', function() { switchTab(this.getAttribute('data-tab')); });\n  });\n\n  if ('IntersectionObserver' in window) {\n    var observer = new IntersectionObserver(function(entries) {\n      entries.forEach(function(entry) {\n        if (entry.isIntersecting && !hasAnimated) {\n          hasAnimated = true;\n          setTimeout(animateAllStats, 300);\n        }\n      });\n    }, { threshold: 0.3 });\n    var section = document.getElementById('transformational-section');\n    if (section) observer.observe(section);\n  }\n})();\n</script>",
