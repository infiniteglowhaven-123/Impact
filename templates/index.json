4 24\" fill=\"#DEF46C\" stroke=\"#000\" stroke-width=\"1.5\"><path d=\"M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z\"/></svg>\n    </div>\n    <div class=\"oo-reviews-aggregate\">\n      <div class=\"oo-reviews-score\">4,9</div>\n      <div class=\"oo-reviews-score-detail\">\n        <div class=\"oo-stars\">★★★★★</div>\n        <div class=\"oo-reviews-count\">Basé sur 20 000+ avis vérifiés</div>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"oo-photos-strip\">\n    <img class=\"oo-photo-thumb\" src=\"https://cdn.shopify.com/s/files/1/0713/6952/3289/files/O_ORIGINE-6.jpg?v=1772240972\" alt=\"Résultat client 1\">\n\n    <img class=\"oo-photo-thumb\" src=\"https://cdn.shopify.com/s/files/1/0713/6952/3289/files/4.jpg?v=1772240883\" alt=\"Résultat client 2\">\n<img class=\"oo-photo-thumb\" src=\"https://cdn.shopify.com/s/files/1/0713/6952/3289/files/anyone-here-try-armra-supplement-v0-ccp0yxmnk1se1_jpeg.webp?v=1772239367\" alt=\"Résultat client 1\">\n    <img class=\"oo-photo-thumb\" src=\"https://cdn.shopify.com/s/files/1/0713/6952/3289/files/3.jpg?v=1772240883\" alt=\"Résultat client 3\">\n    <img class=\"oo-photo-thumb\" src=\"https://cdn.shopify.com/s/files/1/0713/6952/3289/files/person-scooping-armra-colostrum.jpg?v=1772239097\" alt=\"Résultat client 4\">\n    <img class=\"oo-photo-thumb\" src=\"https://cdn.shopify.com/s/files/1/0713/6952/3289/files/f9b9c1c3-a3a7-4de4-9cdf-6288ea95b25a_jpg.webp?v=1772239190\" alt=\"Résultat client 5\">\n    <img class=\"oo-photo-thumb\" src=\"https://cdn.shopify.com/s/files/1/0713/6952/3289/files/5cfd94e9-8ddd-41c0-bb1d-92071585ec0a_jpg.webp?v=1772239226\" alt=\"Résultat client 6\">\n  </div>\n\n  <hr class=\"oo-divider\">\n\n  <div id=\"ooReviewsList\">\n\n    <!-- AVIS 1 — visible -->\n    <div class=\"oo-review-card\">\n      <div class=\"oo-review-meta\">\n        <div class=\"oo-review-author\">\n          <div class=\"oo-review-avatar-initials\">S</div>\n          <div>\n            <div class=\"oo-review-name\">Sophie L.</div>\n            <div class=\"oo-verified-badge\"><svg width=\"10\" height=\"10\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#059669\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>Acheteur vérifié</div>\n          </div>\n        </div>\n        <div class=\"oo-review-date\">Il y a 3 jours</div>\n      </div>\n      <div class=\"oo-review-stars\">★★★★★</div>\n      <div class=\"oo-review-headline\">Je me sens comme neuve</div>\n      <div class=\"oo-review-body\">Je n'aurais jamais cru qu'un supplément puisse faire autant. En 3 semaines, ma digestion s'est complètement régularisée, ma peau est plus lumineuse et j'ai une énergie que je n'avais plus depuis des années.</div>\n      <div class=\"oo-review-tag\">OORIGINE Colostrum™</div>\n      <div class=\"oo-review-photos\">\n        <img class=\"oo-review-photo\" src=\"https://cdn.shopify.com/s/files/1/0713/6952/3289/files/bloat-control-513909.webp?v=1772231359\" alt=\"Photo résultat Sophie\">\n      </div>\n    </div>\n\n    <!-- AVIS 2 — visible -->\n    <div class=\"oo-review-card\">\n      <div class=\"oo-review-meta\">\n        <div class=\"oo-review-author\">\n          <div class=\"oo-review-avatar-initials\">M</div>\n          <div>\n            <div class=\"oo-review-name\">Marie-Claire B.</div>\n            <div class=\"oo-verified-badge\"><svg width=\"10\" height=\"10\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#059669\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>Acheteur vérifié</div>\n          </div>\n        </div>\n        <div class=\"oo-review-date\">Il y a 1 semaine</div>\n      </div>\n      <div class=\"oo-review-stars\">★★★★★</div>\n      <div class=\"oo-review-headline\">Mon intestin enfin réparé</div>\n      <div class=\"oo-review-body\">Après des années de ventre ballonné et de fatigue chronique, OORIGINE a tout changé. Dès la 2ème semaine j'ai senti la différence. Mon gastro n'en revenait pas lors de mon dernier bilan.</div>\n      <div class=\"oo-review-tag\">OORIGINE Colostrum™</div>\n    </div>\n\n    <!-- AVIS 3 — visible -->\n    <div class=\"oo-review-card\">\n      <div class=\"oo-review-meta\">\n        <div class=\"oo-review-author\">\n          <div class=\"oo-review-avatar-initials\">K</div>\n          <div>\n            <div class=\"oo-review-name\">Keith N.</div>\n            <div class=\"oo-verified-badge\"><svg width=\"10\" height=\"10\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#059669\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>Acheteur vérifié</div>\n          </div>\n        </div>\n        <div class=\"oo-review-date\">Il y a 1 mois</div>\n      </div>\n      <div class=\"oo-review-stars\">★★★★★</div>\n      <div class=\"oo-review-headline\">Produit incroyable</div>\n      <div class=\"oo-review-body\">J'ai remarqué une amélioration de ma santé intestinale, de ma peau et de mon énergie globale. Les changements sont impressionnants, ça fait un mois et je me sens comme neuf.</div>\n      <div class=\"oo-review-tag\">OORIGINE Colostrum™</div>\n    </div>\n\n    <!-- AVIS 4 — visible -->\n    <div class=\"oo-review-card\">\n      <div class=\"oo-review-meta\">\n        <div class=\"oo-review-author\">\n          <div class=\"oo-review-avatar-initials\">A</div>\n          <div>\n            <div class=\"oo-review-name\">Amélie R.</div>\n            <div class=\"oo-verified-badge\"><svg width=\"10\" height=\"10\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#059669\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>Acheteur vérifié</div>\n          </div>\n        </div>\n        <div class=\"oo-review-date\">Il y a 2 semaines</div>\n      </div>\n      <div class=\"o