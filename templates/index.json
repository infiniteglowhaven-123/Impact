        "liquid": "<style>\n@import url('https://fonts.cdnfonts.com/css/neue-montreal');\n\n.oo-reviews-section {\n  max-width: 900px;\n  margin: 0 auto;\n  padding: 60px 20px;\n  font-family: 'Neue Montreal', 'Inter', sans-serif;\n}\n\n.oo-reviews-header { margin-bottom: 32px; }\n\n.oo-reviews-trust {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  margin-bottom: 16px;\n}\n\n.oo-reviews-trust-icon {\n  width: 34px;\n  height: 34px;\n  background: #DEF46C;\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  flex-shrink: 0;\n}\n\n.oo-reviews-trust-text {\n  font-size: 13px;\n  color: #666;\n  font-weight: 300;\n  line-height: 1.4;\n}\n\n.oo-reviews-trust-text strong {\n  display: block;\n  font-size: 15px;\n  font-weight: 600;\n  color: #000;\n}\n\n.oo-reviews-title {\n  font-size: 11px;\n  font-weight: 500;\n  letter-spacing: 2.5px;\n  text-transform: uppercase;\n  color: #999;\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  margin-bottom: 20px;\n}\n\n.oo-reviews-aggregate {\n  display: flex;\n  align-items: center;\n  gap: 24px;\n  padding: 24px;\n  background: #FAFAFA;\n  border: 1px solid #e8e8e8;\n  border-radius: 6px;\n  margin-bottom: 28px;\n}\n\n.oo-reviews-score {\n  font-size: 52px;\n  font-weight: 300;\n  color: #000;\n  line-height: 1;\n  letter-spacing: -2px;\n}\n\n.oo-reviews-score-detail {\n  display: flex;\n  flex-direction: column;\n  gap: 5px;\n}\n\n.oo-stars { color: #000; font-size: 18px; letter-spacing: 3px; }\n\n.oo-reviews-count {\n  font-size: 12px;\n  color: #999;\n  font-weight: 300;\n  letter-spacing: 0.3px;\n}\n\n.oo-photos-strip {\n  display: flex;\n  gap: 8px;\n  overflow-x: auto;\n  scrollbar-width: none;\n  margin-bottom: 32px;\n  padding-bottom: 4px;\n}\n\n.oo-photos-strip::-webkit-scrollbar { display: none; }\n\n.oo-photo-thumb {\n  width: 88px;\n  height: 88px;\n  border-radius: 4px;\n  object-fit: cover;\n  flex-shrink: 0;\n  cursor: pointer;\n  border: 1px solid #e8e