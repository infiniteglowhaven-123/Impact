        "remove_horizontal_spacing": true,
        "liquid": "<style>\n/* --- TICKER CONVERSION ULTIME --- */\n\n.oor-ticker-bleed {\n  background: #0B192C; \n  width: 100vw;\n  margin-left: calc(50% - 50vw);\n  padding: 16px 0;\n  overflow: hidden;\n  position: relative;\n  display: flex;\n  border-top: 1px solid rgba(255,255,255,0.1);\n  border-bottom: 1px solid rgba(255,255,255,0.1);\n}\n\n.ticker-wrapper {\n  display: flex;\n  overflow: hidden;\n  white-space: nowrap;\n  width: 100%;\n}\n\n.ticker-track {\n  display: inline-flex;\n  align-items: center;\n  animation: ticker-scroll 35s linear infinite;\n}\n\n.ticker-wrapper:hover .ticker-track {\n  animation-play-state: paused;\n}\n\n.ticker-track span {\n  font-family: 'Inter', -apple-system, sans-serif;\n  font-size: 15px; \n  font-weight: 600; \n  letter-spacing: 1.5px;\n  color: #FFFFFF; \n  text-transform: uppercase;\n  display: inline-flex;\n  align-items: center;\n  margin-right: 40px;\n}\n\n/* Les mots \"Autorité\" en couleur accent (Le vert fluo/lime convertit extrêmement bien sur fond sombre) */\n.ticker-track span.authority {\n  color: #DEF46C; /* Le vert lime de ton badge \"Science\" */\n  font-weight: 700;\n}\n\n/* L'étoile séparatrice */\n.ticker-track span::after {\n  content: '✦';\n  font-size: 13px;\n  color: rgba(255,255,255,0.3); /* Plus discret pour laisser parler le texte */\n  margin-left: 40px;\n}\n\n@keyframes ticker-scroll {\n  0% { transform: translateX(0); }\n  100% { transform: translateX(-50%); } \n}\n\n/* MOBILE RESPONSIVE */\n@media (max-width: 768px) {\n  .oor-ticker-bleed {\n    padding: 12px 0;\n  }\n  .ticker-track span {\n    font-size: 13px; \n    letter-spacing: 1px;\n    margin-right: 25px;\n  }\n  .ticker-track span::after {\n    margin-left: 25px;\n  }\n}\n</style>\n\n<div class=\"oor-ticker-bleed\">\n  <div class=\"ticker-wrapper\">\n    <div class=\"ticker-track\">\n      <!-- SET 1 : Alternance Bénéfice / Autorité -->\n      <span>RÉGÉNÈRE L'INTESTIN</span>\n      <span class=\"authority\">N°1 EN FRANCE</span>\n      <span>ÉNERGIE CONSTANTE</span>\n      <span class=\"authority\">★ 20 000+ CLIENTS</span>\n      <span>IMMUNITÉ BLINDÉE</span>\n      <span class=\"authority\">TESTÉ EN LABO</span>\n      <span>PEAU & CHEVEUX</span>\n      <span class=\"authority\">SATISFAIT OU REMBOURSÉ</span>\n\n      <!-- SET 2 : Copie exacte -->\n      <span>RÉGÉNÈRE L'INTESTIN</span>\n      <span class=\"authority\">N°1 EN FRANCE</span>\n      <span>ÉNERGIE CONSTANTE</span>\n      <span class=\"authority\">★ 20 000+ CLIENTS</span>\n      <span>IMMUNITÉ BLINDÉE</span>\n      <span class=\"authority\">TESTÉ EN LABO</span>\n      <span>PEAU & CHEVEUX</span>\n      <span class=\"authority\">SATISFAIT OU REMBOURSÉ</span>\n    </div>\n  </div>\n</div>",
