0 5px 0 #7f1d1d;\n  transition: transform 0.15s, box-shadow 0.15s;\n  text-transform: uppercase;\n}\n.hiw-btn:hover {\n  transform: translateY(-2px);\n  box-shadow: 0 7px 0 #7f1d1d;\n  color: #fff;\n}\n.hiw-guarantee {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 7px;\n  margin-top: 14px;\n  font-size: 0.78rem;\n  font-weight: 700;\n  color: #aaa;\n  letter-spacing: 0.5px;\n  text-transform: uppercase;\n}\n.hiw-guarantee svg {\n  width: 15px;\n  height: 15px;\n  stroke: #aaa;\n  fill: none;\n  flex-shrink: 0;\n}\n@media (max-width: 900px) {\n  .hiw-inner {\n    grid-template-columns: 1fr;\n  }\n  .hiw-left {\n    min-height: 300px;\n  }\n  .hiw-right {\n    padding: 36px 20px;\n  }\n  .hiw-right h2 {\n    font-size: 1.5rem;\n  }\n  .hiw-stats {\n    grid-template-columns: repeat(2, 1fr);\n  }\n  .hiw-stat img {\n    width: 64px;\n    height: 64px;\n  }\n  .hiw-stat-num {\n    font-size: 1.3rem;\n  }\n  .hiw-stat-text {\n    font-size: 0.75rem;\n  }\n  .hiw-btn,\n  .hiw-guarantee {\n    display: none;\n  }\n}\n</style>\n\n<section class=\"hiw-section\">\n  <div class=\"hiw-inner\">\n    <div class=\"hiw-left\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0770/2016/8389/files/p_why_is_your_dog_behaving_badly_p__2_db9ddaea-efe9-4454-85cd-200db6969a06.webp?v=1772740174\" alt=\"Chat apaisé par Therapattes\">\n    </div>\n    <div class=\"hiw-right\">\n      <h2>Comment ça fonctionne?</h2>\n      <p>Ces phéromones ciblent les cellules de réponse au stress dans le cerveau, aidant votre chat à se sentir calme et serein.</p>\n      <p>Avoir le diffuseur Therapatte chez vous garde votre chat automatiquement apaisé, assurant un environnement paisible et harmonieux.</p>\n      <div class=\"hiw-stats\">\n        <div class=\"hiw-stat\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0770/2016/8389/files/Frame_1484582179_1.svg?v=1772740180\" alt=\"griffades\">\n          <div class=\"hiw-stat-num\">74%</div>\n          <div class=\"hiw-stat-text\">de Réduction des Griffades & Comportements</div>\n        </div>\n        <div class=\"hiw-stat\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0770/2016/8389/files/Frame_1484582177.svg?v=1772740576\" alt=\"cachettes\">\n          <div class=\"hiw-stat-num\">86%</div>\n          <div class=\"hiw-stat-text\">de Réduction des Cachettes & Peurs</div>\n        </div>\n        <div class=\"hiw-stat\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0770/2016/8389/files/Frame_1484582179.svg?v=1772740607\" alt=\"tension\">\n          <div class=\"hiw-stat-num\">83%</div>\n          <div class=\"hiw-stat-text\">Moins de Tension & Agressivité</div>\n        </div>\n        <div class=\"hiw-stat\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0770/2016/8389/files/Group_427319395_fdc7a250-1cc5-4141-a024-a38d98f9596e.svg?v=1772740652\" alt=\"marquage\">\n          <div class=\"hiw-stat-num\">78%</div>\n          <div class=\"hiw-stat-text\">de Réduction des Marquages Urinaires</div>\n        </div>\n      </div>\n      <button onclick=\"document.querySelector('[class*=shopify-section--featured-product]').scrollIntoView({behavior:'smooth'})\" class=\"hiw-btn\">\n        STOPPER L'ANXIÉTÉ DE MON CHAT !\n      </button>\n      <div class=\"hiw-guarantee\">\n        <svg viewBox=\"0 0 24 24\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n          <path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/>\n        </svg>\n        Garantie Satisfait ou Remboursé 30 Jours\n      </div>\n    </div>\n  </div>\n</section>",
