.last {\n  border-radius: 0 0 20px 0;\n}\n\n/* Dégradé ligne par ligne — du plus foncé au plus clair */\n.cmp-row-cell.therapatte.r1 { background: #d96b4e; }\n.cmp-row-cell.therapatte.r2 { background: #dc7358; }\n.cmp-row-cell.therapatte.r3 { background: #df7b62; }\n.cmp-row-cell.therapatte.r4 { background: #e2836c; }\n.cmp-row-cell.therapatte.r5 { background: #e58b76; }\n.cmp-row-cell.therapatte.r6 { background: #e89380; }\n\n.cmp-check {\n  width: 32px;\n  height: 32px;\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: rgba(255,255,255,0.3);\n}\n.cmp-check svg {\n  width: 17px;\n  height: 17px;\n  stroke: #fff;\n  fill: none;\n  stroke-width: 2.5;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n}\n.cmp-cross {\n  width: 32px;\n  height: 32px;\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: #c0392b;\n}\n.cmp-cross svg {\n  width: 15px;\n  height: 15px;\n  stroke: #fff;\n  fill: none;\n  stroke-width: 2.5;\n  stroke-linecap: round;\n}\n.cmp-row-label strong {\n  font-weight: 800;\n  color: #1a1a2e;\n}\n\n@media (max-width: 768px) {\n  .cmp-section { padding: 40px 16px; }\n  .cmp-heading h2 { font-size: 1.5rem; }\n  .cmp-table { grid-template-columns: 1fr 100px 100px; }\n  .cmp-row-label { font-size: 0.82rem; padding-right: 10px; min-height: 64px; }\n  .cmp-row-cell { min-height: 64px; }\n  .cmp-header-img { width: 58px; height: 58px; }\n  .cmp-col-label { font-size: 0.65rem; letter-spacing: 0.8px; padding: 26px 8px 14px; }\n  .cmp-check, .cmp-cross { width: 26px; height: 26px; }\n  .cmp-check svg { width: 14px; height: 14px; }\n  .cmp-cross svg { width: 12px; height: 12px; }\n}\n</style>\n\n<section class=\"cmp-section\">\n  <div class=\"cmp-heading\">\n    <p>Ce qui rend Therapatte</p>\n    <h2>Bien Supérieur aux Autres</h2>\n  </div>\n  <div class=\"cmp-table\">\n\n    <div></div>\n    <div class=\"cmp-header-col\">\n      <img class=\"cmp-header-img\" src=\"https://cdn.shopify.com/s/files/1/0770/2016/8389/files/group_427319039_100x_1b83efd8-6d05-4426-b7c1-77fa83846d54.avif?v=1772756035\" alt=\"Diffuseur Therapatte\">\n      <div class=\"cmp-col-label therapatte\">THERAPATTE</div>\n    </div>\n    <div class=\"cmp-header-col\">\n      <img class=\"cmp-header-img\" src=\"https://cdn.shopify.com/s/files/1/0770/2016/8389/files/DEFFUSER_BLACK_100x_b4380a80-c25d-4841-836c-f7b678bafcd1.avif?v=1772756037\" alt=\"Autres diffuseurs\">\n      <div class=\"cmp-col-label others\">AUTRES</div>\n    </div>\n\n    <div class=\"cmp-row-label\"><span><strong>Double mélange apaisant :</strong> Deux phéromones pour une tranquillité doublée.</span></div>\n    <div class=\"cmp-row-cell therapatte r1\"><div class=\"cmp-check\"><svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg></div></div>\n    <div class=\"cmp-row-cell others\"><div class=\"cmp-cross\"><svg viewBox=\"0 0 24 24\"><line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"/><line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"/></svg></div></div>\n\n    <div class=\"cmp-row-label alt\"><span><strong>Deux mois d'efficacité :</strong> 60 jours d'harmonie par diffuseur.</span></div>\n    <div class=\"cmp-row-cell therapatte r2\"><div class=\"cmp-check\"><svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg></div></div>\n    <div class=\"cmp-row-cell others alt\"><div class=\"cmp-cross\"><svg viewBox=\"0 0 24 24\"><line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"/><line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"/></svg></div></div>\n\n    <div class=\"cmp-row-label\"><span><strong>Confort pur et sûr :</strong> Sans odeur, sans irritant, calme naturel.</span></div>\n    <div class=\"cmp-row-cell therapatte r3\"><div class=\"cmp-check\"><svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg></div></div>\n    <div class=\"cmp-row-cell others\"><div class=\"cmp-cross\"><svg viewBox=\"0 0 24 24\"><line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"/><line x1=\"6\"