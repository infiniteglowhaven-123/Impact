y-content: center;\n  box-shadow: 0 4px 14px rgba(232,99,42,0.4);\n  transition: background 0.2s, transform 0.2s;\n  -webkit-tap-highlight-color: transparent;\n}\n.tp-btn:hover {\n  background: #c95020;\n  transform: translateY(-50%) scale(1.08);\n}\n.tp-btn.prev { left: 0; }\n.tp-btn.next { right: 0; }\n.tp-dots {\n  display: none;\n  justify-content: center;\n  gap: 8px;\n  margin-top: 20px;\n}\n.tp-dot {\n  width: 8px;\n  height: 8px;\n  border-radius: 50%;\n  background: #ddd;\n  transition: background 0.25s, transform 0.25s;\n  cursor: pointer;\n}\n.tp-dot.active {\n  background: #e8632a;\n  transform: scale(1.25);\n}\n@media (max-width: 768px) {\n  .tp-card {\n    min-width: 100%;\n    max-width: 100%;\n  }\n  .tp-btn {\n    width: 32px;\n    height: 32px;\n    font-size: 0.85rem;\n    box-shadow: 0 2px 8px rgba(232,99,42,0.35);\n    top: 38%;\n  }\n  .tp-wrapper { padding: 0 40px; }\n  .tp-dots { display: flex; }\n}\n</style>\n\n<section class=\"tp-reviews\">\n  <div class=\"tp-wrapper\">\n    <button class=\"tp-btn prev\" id=\"tpPrev\" aria-label=\"Avis précédent\">&#8592;</button>\n    <div class=\"tp-overflow\" id=\"tpOverflow\">\n      <div class=\"tp-track\" id=\"tpTrack\">\n\n        <div class=\"tp-card\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0770/2016/8389/files/Sans_titre_Logo_-3.jpg?v=1772735210\" alt=\"avis client chat\" draggable=\"false\">\n          <div class=\"tp-body\">\n            <div class=\"tp-stars\">★★★★★</div>\n            <div class=\"tp-title\">Chat beaucoup plus calme et heureux</div>\n            <div class=\"tp-text\">Une amie me l'a recommandé et je suis tellement contente d'avoir essayé ! Mon chat faisait ses besoins partout, mais ça a super bien marché. Il est tellement plus calme et mes chats s'entendent enfin !</div>\n            <div class=\"tp-footer\">\n              <span class=\"tp-author\">Mélissa N.</span>\n              <span class=\"tp-badge\">✔ Achat Vérifié</span>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"tp-card\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0770/2016/8389/files/cat5.webp?v=1772734967\" alt=\"avis client chat\" draggable=\"false\">\n          <div class=\"tp-body\">\n            <div class=\"tp-stars\">★★★★★</div>\n            <div class=\"tp-title\">Je n'en revenais pas que ça marche aussi bien.</div>\n            <div class=\"tp-text\">J'allais presque en faire un chat d'extérieur à cause des marquages urinaires. Après une semaine avec le diffuseur, les marquages ont complètement arrêté !</div>\n            <div class=\"tp-footer\">\n              <span class=\"tp-author\">Donna C.</span>\n              <span class=\"tp-badge\">✔ Achat Vérifié</span>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"tp-card\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0770/2016/8389/files/Sans_titre_Logo_-2.jpg?v=1772734963\" alt=\"avis client chat\" draggable=\"false\">\n          <div class=\"tp-body\">\n            <div class=\"tp-stars\">★★★★★</div>\n            <div class=\"tp-title\">Ça a vraiment fonctionné !</div>\n            <div class=\"tp-text\">Mes chats se battaient tout le temps — sifflements, grognements, attaques. J'ai essayé d'autres diffuseurs sans résultat. Celui-ci a tout changé ! Ils sont tellement plus calmes maintenant.</div>\n            <div class=\"tp-footer\">\n              <span class=\"tp-author\">Patricia S.</span>\n              <span class=\"tp-badge\">✔ Achat Vérifié</span>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"tp-card\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0770/2016/8389/files/Sans_titre_Logo_-3.jpg?v=1772735210\" alt=\"avis client chat\" draggable=\"false\">\n          <div class=\"tp-body\">\n            <div class=\"tp-stars\">★★★★★</div>\n            <div class=\"tp-title\">Résultats visibles dès 48h !</div>\n            <div class=\"tp-text\">Mon chat était très anxieux lors des orages et des visites. Depuis Therapattes, il reste calme et n'a plus peur de rien. Je ne m'y attendais pas si vite !</div>\n            <div class=\"tp-footer\">\n              <span class=\"tp-author\">Sophie M.</span>\n              <span class=\"tp-badge\">✔ Achat Vérifié</span>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"tp-card\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0770/2016/8389/files/cat5.webp?v=1772734967\" alt=\"avis client chat\" draggable=\"false\">\n          <div class=\"tp-body\">\n            <div class=\"tp-stars\">★★★★★</div>\n            <div class=\"tp-title\">Le meilleur investissement pour mon chat</div>\n            <div class=\"tp-text\">Mon vétérinaire me l'a conseillé et c'est la meilleure décision que j'ai prise. Mon chat ronronne à nouveau et est complètement apaisé !</div>\n            <div class=\"tp-footer\">\n              <span class=\"tp-author\">Julie R.</span>\n              <span class=\"tp-badge\">✔ Achat Vérifié</span>\n            </div>\n          </div>\n        </div>\n\n      </div>\n    </div>\n    <button class=\"tp-btn next\" id=\"tpNext\" aria-label=\"Avis suivant\">&#8594;</button>\n  </div>\n  <div class=\"tp-dots\" id=\"tpDots\"></div>\n</section>\n\n<script>\n(function() {\n  var REAL = 3; /* nombre d'avis réels */\n  var track = document.getElementById('tpTrack');\n  var overflow = document.getElementById('tpOverflow');\n  var dotsContainer = document.getElementById('tpDots');\n  var prevBtn = document.getElementById('tpPrev');\n  var nextBtn = document.getElementById('tpNext');\n  var isAnimating = false;\n\n  /* 3 dots fixes */\n  for (var i = 0; i < REAL; i++) {\n    var dot = document.createElement('span');\n    dot.className = 'tp-dot' + (i === 0 ? ' active' : '');\n    dot.setAttribute('data-index', i);\n    dot.addEventListener('click', function() {\n      goToReal(parseInt(this.getAttribute('data-index')));\n    });\n    dotsContainer.appendChild(dot);\n  }\n\n  function isMobile() { return window.innerWidth <= 768; }\n\n  function getCardWidth() {\n    return track.children[0].offsetWidth + 24;\n  }\n\n  /* Index courant dans le DOM (0 à 4) */\n  var domIndex = 0;\n\n  /* Aller à un index DOM sans animation (pour le jump invisible) */\n  function jumpTo(index) {\n    track.style.transition = 'none';\n    track.style.transform = 'translateX(-' + (index * getCardWidth()) + 'px)';\n    domIndex = index;\n  }\n\n  /* Aller à un index DOM avec animation */\n  function slideTo(index, callback) {\n    isAnimating = true;\n    track.style.transition = 'transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94)';\n    track.style.transform = 'translateX(-' + (index * getCardWidth()) + 'px)';\n    domIndex = index;\n    track.addEventListener('transitionend', function handler() {\n      track.removeEventListener('transitionend', handler);\n      isAnimating = false;\n      if (callback) callback();\n    });\n  }\n\n  function updateDots() {\n    var vis = isMobile() ? 1 : 3;\n    /* Sur desktop on affiche 3 cartes → index 0 = avis 1,2,3 → dot 0\n       Sur mobile on avance une par une → modulo REAL */\n    var activeDot = domIndex % REAL;\n    var dots = dotsContainer.querySelectorAll('.tp-dot');\n    dots.forEach(function(d, i) {\n      d.classList.toggle('active', i === activeDot);\n    });\n  }\n\n  function goNext() {\n    if (isAnimating) return;\n    var vis = isMobile() ? 1 : 3;\n    var total = track.children.length; /* 5 cartes dans le DOM */\n    var max = total - vis;\n\n    if (domIndex < max) {\n      slideTo(domIndex + 1, updateDots);\n    } else {\n      /* On est au bout → slide vers une carte clone puis jump au début */\n      slideTo(domIndex + 1, function() {\n        jumpTo(0);\n        updateDots();\n      });\n    }\n    updateDots();\n  }\n\n  function goPrev() {\n    if (isAnimating) return;\n    if (domIndex > 0) {\n      slideTo(domIndex - 1, updateDots);\n    } else {\n      /* On est au début → jump à la fin sans animation puis slide back */\n      var vis = isMobile() ? 1 : 3;\n      var total = track.children.length;\n      jumpTo(total - vis);\n      setTimeout(function() {\n        slideTo(total - vis - 1, updateDots);\n      }, 20);\n    }\n    updateDots();\n  }\n\n  function goToReal(realIndex) {\n    if (isAnimating) return;\n    slideTo(realIndex, updateDots);\n  }\n\n  prevBtn.addEventListener('click', goPrev);\n  nextBtn.addEventListener('click', goNext);\n\n  /* Swipe */\n  var touchStartX = 0;\n  var touchStartY = 0;\n  var isDragging = false;\n  var dragDelta = 0;\n\n  overflow.addEventListener('touchstart', function(e) {\n    touchStartX = e.touches[0].clientX;\n    touchStartY = e.touches[0].clientY;\n    isDragging = true;\n    dragDelta = 0;\n    track.style.transition = 'none';\n  }, { passive: true });\n\n  overflow.addEventListener('touchmove', function(e) {\n    if (!isDragging) return;\n    var dx = e.touches[0].clientX - touchStartX;\n    var dy = e.touches[0].clientY - touchStartY;\n    if (Math.abs(dy) > Math.abs(dx) && Math.abs(dragDelta) < 5) {\n      isDragging = false;\n      track.style.transition = 'transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94)';\n      return;\n    }\n    dragDelta = dx;\n    var baseOffset = domIndex * getCardWidth();\n    track.style.transform = 'translateX(' + (-baseOffset + dx) + 'px)';\n  }, { passive: true });\n\n  overflow.addEventListener('touchend', function() {\n    if (!isDragging) return;\n    isDragging = false;\n    if (dragDelta < -50) {\n      goNext();\n    } else if (dragDelta > 50) {\n      goPrev();\n    } else {\n      slideTo(domIndex);\n    }\n  });\n\n  window.addEventListener('resize', function() {\n    jumpTo(0);\n    updateDots();\n  });\n\n  updateDots();\n})();\n</script>",
