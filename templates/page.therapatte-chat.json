gn: center;\n    letter-spacing: 1px;\n    margin-bottom: 8px;\n  }\n  .ing-right p {\n    text-align: center;\n    font-size: 0.85rem;\n    margin-bottom: 20px;\n  }\n  .ing-item {\n    padding: 16px 20px;\n  }\n  .ing-icon {\n    width: 64px;\n    height: 64px;\n  }\n  .ing-icon img {\n    width: 38px;\n    height: 38px;\n  }\n  .ing-text {\n    font-size: 0.95rem;\n  }\n}\n</style>\n\n<section class=\"ing-section\">\n  <img class=\"ing-bg\" src=\"https://cdn.shopify.com/s/files/1/0770/2016/8389/files/frame_1484581135_d46e9e10-df69-48e4-9b11-5710426591f6.webp?v=1772755113\" alt=\"\" role=\"presentation\">\n  <img class=\"ing-mobile-img\" src=\"https://cdn.shopify.com/s/files/1/0770/2016/8389/files/frame_1484581135_d46e9e10-df69-48e4-9b11-5710426591f6.webp?v=1772755113\" alt=\"Ingrédients Therapattes\">\n  <div class=\"ing-right\">\n    <h2>Ingrédients</h2>\n    <p>Installez les diffuseurs dans les zones fréquentées par votre chat, chacun couvrant 65 m². Les murs bloquent les phéromones.</p>\n    <div class=\"ing-list\">\n      <div class=\"ing-item\">\n        <div class=\"ing-icon\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0770/2016/8389/files/Isolation_Mode.svg?v=1772755346\" alt=\"phéromone\">\n        </div>\n        <div class=\"ing-text\">Phéromone faciale féline (F3) analogue 10%</div>\n      </div>\n      <div class=\"ing-item\">\n        <div class=\"ing-icon\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0770/2016/8389/files/Group_427319415.svg?v=1772755364\" alt=\"hydrocarbure\">\n        </div>\n        <div class=\"ing-text\">Hydrocarbure isoparaffinique 48 mL</div>\n      </div>\n    </div>\n  </div>\n</section>",
