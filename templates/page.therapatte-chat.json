        "liquid": "<style>\n@import url('https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700;800&display=swap');\n.rev-section {\n  background: #fff8f4;\n  padding: 60px 20px;\n  font-family: 'Open Sans', sans-serif;\n}\n.rev-heading {\n  text-align: center;\n  margin-bottom: 40px;\n}\n.rev-heading h2 {\n  font-size: 1.9rem;\n  font-weight: 800;\n  color: #1a1a2e;\n  margin: 0 0 8px;\n}\n.rev-heading h3 {\n  font-size: 1.9rem;\n  font-weight: 800;\n  font-style: italic;\n  color: #c0392b;\n  margin: 0;\n}\n.rev-wrapper {\n  position: relative;\n  max-width: 900px;\n  margin: 0 auto;\n  display: flex;\n  align-items: center;\n  gap: 16px;\n}\n.rev-btn {\n  background: #c0392b;\n  color: #fff;\n  border: none;\n  border-radius: 50%;\n  width: 44px;\n  height: 44px;\n  font-size: 1.2rem;\n  cursor: pointer;\n  flex-shrink: 0;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  box-shadow: 0 3px 10px rgba(192,57,43,0.3);\n  transition: background 0.2s;\n  -webkit-tap-highlight-color: transparent;\n}\n.rev-btn:hover { background: #922b21; }\n.rev-overflow {\n  overflow: hidden;\n  flex: 1;\n}\n.rev-track {\n  display: flex;\n  transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);\n  will-change: transform;\n}\n.rev-card {\n  min-width: 100%;\n  background: #fff;\n  border-radius: 16px;\n  border: 1px solid #f0e8e0;\n  padding: 36px;\n  display: flex;\n  gap: 32px;\n  align-items: flex-start;\n  box-shadow: 0 2px 20px rgba(0,0,0,0.04);\n}\n.rev-img {\n  width: 260px;\n  height: 260px;\n  border-radius: 12px;\n  object-fit: cover;\n  flex-shrink: 0;\n  pointer-events: none;\n  user-select: none;\n  -webkit-user-drag: none;\n}\n.rev-body {\n  display: flex;\n  flex-direction: column;\n  justify-content: space-between;\n  flex: 1;\n  min-height: 260px;\n}\n.rev-stars {\n  color: #f5a623;\n  font-size: 1.3rem;\n  letter-spacing: 3px;\n  margin-bottom: 14px;\n}\n.rev-title {\n  font-size: 1.15rem;\n  font-weight: 800;\n  color: #1a1a2e;\n  margin: 0 0 16px;\n}\n.rev-text {\n  font-size: 0.92rem;\n  color: #555;\n  line-height: 1.75;\n  margin: 0;\n  flex: 1;\n}\n.rev-footer {\n  display: flex;\n  align-items: center;\n  gap: 20px;\n  margin-top: 28px;\n  padding-top: 20px;\n  border-top: 1px solid #f0e8e0;\n}\n.rev-author-name {\n  font-size: 0.92rem;\n  font-weight: 700;\n  color: #c0392b;\n}\n.rev-author-tag {\n  font-size: 0.82rem;\n  color: #999;\n}\n.rev-sep {\n  width: 1px;\n  height: 36px;\n  background: #ddd;\n}\n.rev-purchased-label {\n  font-size: 0.82rem;\n  font-weight: 700;\n  color: #c0392b;\n}\n.rev-purchased-val {\n  font-size: 0.82rem;\n  color: #555;\n}\n.rev-dots {\n  display: flex;\n  justify-content: center;\n  gap: 10px;\n  margin-top: 24px;\n}\n.rev-dot {\n  width: 10px;\n  height: 10px;\n  border-radius: 50%;\n  background: #ddd;\n  cursor: pointer;\n  transition: background 0.2s, transform 0.2s;\n}\n.rev-dot.active {\n  background: #c0392b;\n  transform: scale(1.25);\n}\n@media (max-width: 700px) {\n  .rev-card {\n    flex-direction: column;\n    padding: 24px;\n  }\n  .rev-img {\n    width: 100%;\n    height: 220px;\n  }\n  .rev-body {\n    min-height: auto;\n  }\n  .rev-heading h2,\n  .rev-heading h3 {\n    font-size: 1.3rem;\n  }\n  .rev-btn {\n    width: 32px;\n    height: 32px;\n    font-size: 0.85rem;\n  }\n}\n</style>\n\n<section class=\"rev-section\">\n  <div class=\"rev-heading\">\n    <h2>Ne Nous Croyez Pas Sur Parole!</h2>\n    <h3>Écoutez Nos Clients Satisfaits</h3>\n  </div>\n  <div class=\"rev-wrapper\">\n    <button class=\"rev-btn\" id=\"revPrev\">&#8592;</button>\n    <div class=\"rev-overflow\" id=\"revOverflow\">\n      <div class=\"rev-track\" id=\"revTrack\">\n        <div class=\"rev-card\">\n          <img class=\"rev-img\" src=\"https://cdn.shopify.com/s/files/1/0770/2016/8389/files/cat3.jpg?v=1772753759\" alt=\"Avis Thomas U.\" draggable=\"false\">\n          <div class=\"rev-body\">\n            <div>\n              <div class=\"rev-stars\">★★★★★</div>\n              <div class=\"rev-title\">Le diffuseur anti-stress qui fait vraiment la différence !</div>\n              <p class=\"rev-text\">Mon chat marquait partout dans la maison depuis des mois. Depuis que j'utilise le diffuseur Therapatte, les marquages ont complètement disparu. Je peux enfin profiter de mon chat sans stress !</p>\n            </div>\n            <div class=\"rev-footer\">\n              <div>\n                <div class=\"rev-author-name\">Thomas U.</div>\n                <div class=\"rev-author-tag\">Achat Vérifié</div>\n              </div>\n              <div class=\"rev-sep\"></div>\n              <div>\n                <div class=\"rev-purchased-label\">Acheté :</div>\n                <div class=\"rev-purchased-val\">Pack 3x</div>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"rev-card\">\n          <img class=\"rev-img\" src=\"https://cdn.shopify.com/s/files/1/0770/2016/8389/files/Sans_titre_Logo_-4.jpg?v=1772753895\" alt=\"Avis Stéphanie V.\" draggable=\"false\">\n          <div class=\"rev-body\">\n            <div>\n              <div class=\"rev-stars\">★★★★★</div>\n              <div class=\"rev-title\">Cliente fidèle !</div>\n              <p class=\"rev-text\">Je suis maman d'accueil pour chats, j'en ai souvent 12 à la maison. Quand un nouveau arrive, c'est toujours la tension. Avec Therapatte, l'ambiance est tellement plus zen — je recommande pour la 3ème fois !</p>\n            </div>\n            <div class=\"rev-footer\">\n              <div>\n                <div class=\"rev-author-name\">Stéphanie V.</div>\n                <div class=\"rev-author-tag\">Achat Vérifié</div>\n              </div>\n              <div class=\"rev-sep\"></div>\n              <div>\n                <div class=\"rev-purchased-label\">Acheté :</div>\n                <div class=\"rev-purchased-val\">Pack 3x</div>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"rev-card\">\n          <img class=\"rev-img\" src=\"https://cdn.shopify.com/s/files/1/0770/2016/8389/files/cat1.jpg?v=1772753757\" alt=\"Avis Jacques B.\" draggable=\"false\">\n          <div class=\"rev-body\">\n            <div>\n              <div class=\"rev-stars\">★★★★★</div>\n              <div class=\"rev-title\">Adieu le stress et les dégâts !</div>\n              <p class=\"rev-text\">Notre chatte était très perturbée après une inondation au sous-sol. Elle avait commencé à faire ses besoins partout. Depuis Therapatte, elle est complètement apaisée et tout est rentré dans l'ordre en quelques jours.</p>\n            </div>\n            <div class=\"rev-footer\">\n              <div>\n                <div class=\"rev-author-name\">Jacques B.</div>\n                <div class=\"rev-author-tag\">Achat Vérifié</div>\n              </div>\n              <div class=\"rev-sep\"></div>\n              <div>\n                <div class=\"rev-purchased-label\">Acheté :</div>\n                <div class=\"rev-purchased-val\">Pack 2x</div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n    <button class=\"rev-btn\" id=\"revNext\">&#8594;</button>\n  </div>\n  <div class=\"rev-dots\" id=\"revDots\">\n    <div class=\"rev-dot active\" data-index=\"0\"></div>\n    <div class=\"rev-dot\" data-index=\"1\"></div>\n    <div class=\"rev-dot\" data-index=\"2\"></div>\n  </div>\n</section>\n\n<script>\n(function() {\n  var revIndex = 0;\n  var revTotal = 3;\n  var track = document.getElementById('revTrack');\n  var overflow = document.getElementById('revOverflow');\n  var dots = document.querySelectorAll('.rev-dot');\n\n  function revUpdate() {\n    track.style.transform = 'translateX(-' + (revIndex * 100) + '%)';\n    dots.forEach(function(d, i) {\n      d.classList.toggle('active', i === revIndex);\n    });\n  }\n\n  function revMove(dir) {\n    revIndex += dir;\n    if (revIndex < 0) revIndex = revTotal - 1;\n    if (revIndex >= revTotal) revIndex = 0;\n    revUpdate();\n  }\n\n  document.getElementById('revPrev').addEventListener('click', function() { revMove(-1); });\n  document.getElementById('revNext').addEventListener('click', function() { revMove(1); });\n\n  dots.forEach(function(dot) {\n    dot.addEventListener('click', function() {\n      revIndex = parseInt(this.getAttribute('data-index'));\n      revUpdate();\n    });\n  });\n\n  /* Swipe */\n  var touchStartX = 0;\n  var touchStartY = 0;\n  var isDragging = false;\n  var dragDelta = 0;\n\n  overflow.addEventListener('touchstart', function(e) {\n    touchStartX = e.touches[0].clientX;\n    touchStartY = e.touches[0].clientY;\n    isDragging = true;\n    dragDelta = 0;\n    track.style.transition = 'none';\n  }, { passive: true });\n\n  overflow.addEventListener('touchmove', function(e) {\n    if (!isDragging) return;\n    var dx = e.touches[0].clientX - touchStartX;\n    var dy = e.touches[0].clientY - touchStartY;\n    if (Math.abs(dy) > Math.abs(dx) && Math.abs(dragDelta) < 5) {\n      isDragging = false;\n      track.style.transition = 'transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94)';\n      return;\n    }\n    dragDelta = dx;\n    var baseOffset = revIndex * 100;\n    var pct = (dx / overflow.offsetWidth) * 100;\n    track.style.transform = 'translateX(' + (-baseOffset + pct) + '%)';\n  }, { passive: true });\n\n  overflow.addEventListener('touchend', function() {\n    if (!isDragging) return;\n    isDragging = false;\n    track.style.transition = 'transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94)';\n    if (dragDelta < -50) {\n      revMove(1);\n    } else if (dragDelta > 50) {\n      revMove(-1);\n    } else {\n      revUpdate();\n    }\n  });\n})();\n</script>",
