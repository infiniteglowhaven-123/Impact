        "liquid": "<style>\n@import url('https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700;800&display=swap');\n\n.htw-section {\n  font-family: 'Open Sans', sans-serif;\n  background: linear-gradient(180deg, #fce8dc 0%, #f5d5c0 100%);\n  padding: 60px 40px;\n}\n\n.htw-title {\n  text-align: center;\n  font-size: 2rem;\n  font-weight: 700;\n  font-style: italic;\n  color: #fff;\n  margin: 0 0 40px;\n}\n\n.htw-wrapper {\n  max-width: 1100px;\n  margin: 0 auto;\n}\n\n.htw-overflow {\n  overflow: hidden;\n}\n\n.htw-track {\n  display: flex;\n  gap: 20px;\n  transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);\n  will-change: transform;\n}\n\n.htw-card {\n  background: #fff;\n  border-radius: 16px;\n  overflow: hidden;\n  flex-shrink: 0;\n  width: calc(33.333% - 14px);\n}\n\n.htw-card-img img {\n  width: 100%;\n  height: 280px;\n  object-fit: cover;\n  display: block;\n  pointer-events: none;\n  user-select: none;\n  -webkit-user-drag: none;\n}\n\n.htw-card-body {\n  padding: 18px 20px 22px;\n}\n\n.htw-card-title {\n  font-size: 1rem;\n  font-weight: 800;\n  color: #1a1a2e;\n  margin: 0;\n}\n\n.htw-dots {\n  display: flex;\n  justify-content: center;\n  gap: 8px;\n  margin-top: 28px;\n}\n\n.htw-dot {\n  width: 10px;\n  height: 10px;\n  border-radius: 50%;\n  background: rgba(0,0,0,0.2);\n  cursor: pointer;\n  transition: all 0.2s;\n  border: none;\n  padding: 0;\n}\n\n.htw-dot.active {\n  background: #1a1a2e;\n  width: 28px;\n  border-radius: 10px;\n}\n\n@media (max-width: 768px) {\n  .htw-section { padding: 40px 16px; }\n  .htw-title { font-size: 1.5rem; margin-bottom: 24px; }\n  .htw-card {\n    width: calc(100vw - 64px);\n  }\n  .htw-card-img img { height: 220px; }\n}\n</style>\n\n<section class=\"htw-section\">\n  <h2 class=\"htw-title\">Comment Utiliser</h2>\n\n  <div class=\"htw-wrapper\">\n    <div class=\"htw-overflow\" id=\"htwOverflow\">\n      <div class=\"htw-track\" id=\"htwTrack\">\n\n        <div class=\"htw-card\">\n          <div class=\"htw-card-img\">\n            <img src=\"https://cdn.shopify.com/s/files/1/0770/2016/8389/files/ETAPE_1.svg?v=1772755756\" alt=\"Étape 1 — Assemblez le diffuseur et la recharge\">\n          </div>\n          <div class=\"htw-card-body\">\n            <div class=\"htw-card-title\">Assemblez le diffuseur et la recharge</div>\n          </div>\n        </div>\n\n        <div class=\"htw-card\">\n          <div class=\"htw-card-img\">\n            <img src=\"https://cdn.shopify.com/s/files/1/0770/2016/8389/files/1.svg?v=1772755687\" alt=\"Étape 2 — Trouvez les endroits idéaux\">\n          </div>\n          <div class=\"htw-card-body\">\n            <div class=\"htw-card-title\">Trouvez les endroits idéaux</div>\n          </div>\n        </div>\n\n        <div class=\"htw-card\">\n          <div class=\"htw-card-img\">\n            <img src=\"https://cdn.shopify.com/s/files/1/0770/2016/8389/files/2.svg?v=1772755688\" alt=\"Étape 3 — Branchez-les\">\n          </div>\n          <div class=\"htw-card-body\">\n            <div class=\"htw-card-title\">Branchez-les</div>\n          </div>\n        </div>\n\n        <div class=\"htw-card\">\n          <div class=\"htw-card-img\">\n            <img src=\"https://cdn.shopify.com/s/files/1/0770/2016/8389/files/3.svg?v=1772755687\" alt=\"Étape 4 — Laissez-les agir\">\n          </div>\n          <div class=\"htw-card-body\">\n            <div class=\"htw-card-title\">Laissez-les agir</div>\n          </div>\n        </div>\n\n      </div>\n    </div>\n\n    <div class=\"htw-dots\" id=\"htwDots\"></div>\n  </div>\n</section>\n\n<script>\n(function() {\n  var htwIndex = 0;\n  var track = document.getElementById('htwTrack');\n  var overflow = document.getElementById('htwOverflow');\n  var dotsContainer = document.getElementById('htwDots');\n\n  function isMobile() { return window.innerWidth <= 768; }\n  function totalPages() { return isMobile() ? 4 : 2; }\n\n  function buildDots() {\n    dotsContainer.innerHTML = '';\n    var pages = totalPages();\n    for (var i = 0; i < pages; i++) {\n      var btn = document.createElement('button');\n      btn.className = 'htw-dot' + (i === 0 ? ' active' : '');\n      btn.setAttribute('data-index', i);\n      btn.addEventListener('click', function() {\n        htwGo(parseInt(this.getAttribute('data-index')));\n      });\n      dotsContainer.appendChild(btn);\n    }\n  }\n\n  function htwGo(i) {\n    htwIndex = Math.max(0, Math.min(i, totalPages() - 1));\n    htwUpdate();\n  }\n\n  function htwUpdate() {\n    var mobile = isMobile();\n    var startCard = mobile ? htwIndex : (htwIndex === 0 ? 0 : 3);\n    var cardWidth = track.children[0].offsetWidth + 20;\n    track.style.transition = 'transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94)';\n    track.style.transform = 'translateX(-' + (startCard * cardWidth) + 'px)';\n    var dots = dotsContainer.querySelectorAll('.htw-dot');\n    dots.forEach(function(d, i) {\n      d.classList.toggle('active', i === htwIndex);\n    });\n  }\n\n  /* Swipe */\n  var touchStartX = 0;\n  var touchStartY = 0;\n  var isDragging = false;\n  var dragDelta = 0;\n\n  overflow.addEventListener('touchstart', function(e) {\n    touchStartX = e.touches[0].clientX;\n    touchStartY = e.touches[0].clientY;\n    isDragging = true;\n    dragDelta = 0;\n    track.style.transition = 'none';\n  }, { passive: true });\n\n  overflow.addEventListener('touchmove', function(e) {\n    if (!isDragging) return;\n    var dx = e.touches[0].clientX - touchStartX;\n    var dy = e.touches[0].clientY - touchStartY;\n    if (Math.abs(dy) > Math.abs(dx) && Math.abs(dragDelta) < 5) {\n      isDragging = false;\n      track.style.transition = 'transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94)';\n      return;\n    }\n    dragDelta = dx;\n    var mobile = isMobile();\n    var startCard = mobile ? htwIndex : (htwIndex === 0 ? 0 : 3);\n    var cardWidth = track.children[0].offsetWidth + 20;\n    var baseOffset = startCard * cardWidth;\n    var resistance = (htwIndex === 0 && dx > 0) || (htwIndex >= totalPages() - 1 && dx < 0) ? 0.25 : 1;\n    track.style.transform = 'translateX(' + (-baseOffset + dx * resistance) + 'px)';\n  }, { passive: true });\n\n  overflow.addEventListener('touchend', function() {\n    if (!isDragging) return;\n    isDragging = false;\n    if (dragDelta < -50) {\n      htwGo(htwIndex + 1);\n    } else if (dragDelta > 50) {\n      htwGo(htwIndex - 1);\n    } else {\n      htwUpdate();\n    }\n  });\n\n  window.addEventListener('resize', function() {\n    htwIndex = 0;\n    buildDots();\n    htwUpdate();\n  });\n\n  buildDots();\n  htwUpdate();\n})();\n</script>",
